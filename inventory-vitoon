      <td style="text-align:center;font-size:12px">${item.UnitName||'—'}</td>
      <td style="text-align:right">${fmtMoney(ep)}</td>
      <td style="text-align:right">${fmtMoney(item.qty*(ep||0))}</td>
    </tr>`;
  }).join('');

  let nvRowsHtml = '';
  let nvSubtotal = 0;
  if(nvItems.length > 0){
    nvSubtotal = nvItems.reduce((s,c)=>{ const ep=c.customPrice!==undefined?c.customPrice:(c.UnitPrice||c.LastPurchasePrice||0); return s+c.qty*ep; },0);
    nvRowsHtml = `<tr style="background:#FFF0F0;border-top:2px solid #DC2626;">
      <td colspan="7" style="padding:5px 10px;font-size:11px;font-weight:700;color:#DC2626;">รายการสินค้า NV (ไม่มีภาษี)</td>
    </tr>` + nvItems.map((item,i)=>{
