function renderPagination(total,pages){
  const btns=document.getElementById('pageBtns'); btns.innerHTML='';
  if(pages<=1) return;
  const add=(label,page,active,disabled)=>{
    const b=document.createElement('button'); b.className='page-btn'+(active?' active':'');
    b.textContent=label; b.disabled=disabled;
    if(!disabled&&!active) b.onclick=()=>{currentPage=page;renderTable();};
    btns.appendChild(b);
  };
  add('‹',currentPage-1,false,currentPage===1);
  const s=Math.max(1,currentPage-2), e=Math.min(pages,s+4);
  for(let i=s;i<=e;i++) add(i,i,i===currentPage,false);
  add('›',currentPage+1,false,currentPage===pages);
}

