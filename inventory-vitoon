function getPOStatusMap(){
  // คืน map ของ ProductCode → [{poNo, qty, unitName, poDate, received}]
  // received = true ถ้า QtyOnHand ปัจจุบัน > qtyOnHandAtOrder (ของเข้าแล้ว)
  const records = getPORecords();
  const map = {};
  let hasNewReceived = false;

  records.forEach(r => {
    if(r.status === 'cancelled') return;
    (r.items||[]).forEach(it => {
      if((it.cancelledQty||0) >= it.qty) return; // fix: undefined check
      const code = it.ProductCode;
      if(!code) return;

      // ตรวจว่าของเข้าแล้วหรือยัง
      // มี qtyOnHandAtOrder และ allData โหลดแล้ว → ตรวจได้
      // ถ้าไม่มี qtyOnHandAtOrder → ถือว่ายังไม่ได้ตรวจ (ไม่ใช่ received)
      let received = it.received || false;
      // ถ้าไม่มี qtyOnHandAtOrder = PO เก่า ไม่รู้ status → ข้ามไม่แสดง badge
      if(it.qtyOnHandAtOrder === undefined && !it.received) return;
      if(!received && it.qtyOnHandAtOrder !== undefined && allData.length > 0){
        const prod = allData.find(d => d.ProductCode === code);
        const currentQty = prod ? parseFloat(prod.QtyOnHand)||0 : 0;
        received = currentQty > (it.qtyOnHandAtOrder||0);
      }

      const entry = {
        poNo:     r.poNo,
        poDate:   r.poDate,
        qty:      it.qty - (it.cancelledQty||0),
        unitName: it.UnitName||'',
        received: received
      };
      if(!map[code]) map[code] = [];
      map[code].push(entry);
    });
  });

  return map;
}

