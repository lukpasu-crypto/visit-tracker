      </tr>`;
    }).join('');
  }

  const rows = mainRows + nvRowsHtml;
  document.getElementById('printArea').innerHTML = buildPrintHTML(r.poNo, r.poDate, r.supplier||'—', r.contact||'', r.creator||'', r.remark||'', rows, subtotal, vatAmt, total, vatMode, nvSubtotal, nvItems.length>0, r.approverName||'', r.approverSig||'');

  cart = oldCart; vatMode = oldVat; priceMode = oldMode;
  closePOHistory();
  setTimeout(()=>window.print(), 200);
}

