function savePORecord(poNo, poDate, supplier, contact, creator, remark, subtotal, vatAmt, total){
  const records = getPORecords();

  // snapshot QtyOnHand ณ วันที่สั่งซื้อ (เพื่อ detect ของเข้าในภายหลัง)
  const itemsWithSnapshot = JSON.parse(JSON.stringify(cart)).map(item => {
    const prod = allData.find(d => d.ProductCode === item.ProductCode);
    return {
      ...item,
      qtyOnHandAtOrder: prod ? parseFloat(prod.QtyOnHand) || 0 : 0
    };
  });

  const _apvSelS = document.getElementById('poApprover');
  const _apvOptS = _apvSelS ? _apvSelS.options[_apvSelS.selectedIndex] : null;
  const _apvNameS = _apvOptS ? (_apvOptS.dataset.name || '').replace(' ✍️','') : '';
  const _apvSigS  = _apvOptS ? (_apvOptS.dataset.sig || '') : '';
  const _hidePrices = priceMode === 'none';

  const record = {
    poNo, poDate, supplier, contact, creator, remark,
    subtotal, vatAmt, total, vatMode,
    hidePrices: _hidePrices,
    approverName: _apvNameS,
    approverSig: _apvSigS,
    status: 'active',
    items: itemsWithSnapshot,
    createdAt: new Date().toLocaleString('th-TH',{hour12:false}),
    driveUrl: ''
  };
  // บันทึก localStorage ก่อน
  records.unshift(record);
  localStorage.setItem('vitoon_po_records', JSON.stringify(records.slice(0,200)));
  // Sync ขึ้น Sheets — ส่ง 1 แถวสรุปต่อ PO ตรงกับ header: poNo,poDate,supplier,contact,creator,remark,subtotal,vatAmt,total,vatMode,status,cancelledAt,cancelledBy
  const _itemDesc = (record.items||[]).map(it => it.ProductCode+'x'+it.qty).join(', ');
  const _rmk = [record.remark||'', _itemDesc].filter(Boolean).join(' | ');
  const _rows = [[
    record.poNo, record.poDate, record.supplier||'', record.contact||'', record.creator||'',
    _rmk,
    record.hidePrices ? 0 : (record.subtotal||0),
    record.hidePrices ? 0 : (record.vatAmt||0),
    record.hidePrices ? 0 : (record.total||0),
    (record.vatMode||7)+'%',
    'active', '', ''
  ]];
  syncPOtoSheets('save', { rows: _rows });
}

function getPORecords(){
  try { return JSON.parse(localStorage.getItem('vitoon_po_records')||'[]'); }
  catch(e){ return []; }
}

function updatePODriveUrl(poNo, url){
  const records = getPORecords();
  const rec = records.find(r => r.poNo === poNo);
  if(rec){ rec.driveUrl = url; localStorage.setItem('vitoon_po_records', JSON.stringify(records)); }
}


