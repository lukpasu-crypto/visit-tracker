      <h3>👥 จัดการผู้ใช้งาน</h3>
      <button class="um-close" onclick="closeUserMgmt()">✕</button>
    </div>
    <div class="um-body">
      <table class="um-table" id="umTable">
        <thead><tr>
          <th>#</th><th>Username</th><th>ชื่อ</th><th>Role</th><th>จัดการ</th>
        </tr></thead>
        <tbody id="umTableBody"></tbody>
      </table>

      <div class="um-form" id="umForm">
        <div class="um-form-title" id="umFormTitle">➕ เพิ่มผู้ใช้งานใหม่</div>
        <div class="um-row">
          <div class="um-field">
            <label>Username</label>
            <input type="text" id="umUsername" placeholder="ชื่อผู้ใช้ (ตัวเล็ก)">
          </div>
          <div class="um-field">
            <label>ชื่อแสดง</label>
            <input type="text" id="umName" placeholder="ชื่อ-สกุล หรือตำแหน่ง">
          </div>
        </div>
        <div class="um-row">
          <div class="um-field">
            <label>รหัสผ่าน</label>
            <input type="password" id="umPassword" placeholder="รหัสผ่าน">
          </div>
          <div class="um-field">
            <label>Role</label>
            <select id="umRole">
              <option value="staff">พนักงาน (staff)</option>
              <option value="manager">ผู้จัดการ (manager)</option>
              <option value="admin">แอดมิน (admin)</option>
            </select>
          </div>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:4px">
          <button class="btn btn-outline" onclick="cancelEditUser()">ยกเลิก</button>
          <button class="btn btn-primary" onclick="saveUser()">💾 บันทึก</button>
        </div>
      </div>
    </div>
  </div>
</div>


<!-- ═══════════ PO HISTORY MODAL ═══════════ -->
<div id="poHistoryModal">
  <div class="ph-box">
    <div class="ph-header">
      <h3>📄 ประวัติใบสั่งซื้อ (PO History)</h3>
      <button class="ph-close" onclick="closePOHistory()">✕</button>
    </div>
    <div class="ph-toolbar">
      <input type="text" id="phSearch" placeholder="🔍 ค้นหาเลข PO / ผู้ขาย / สินค้า..." oninput="renderPOHistory()">
      <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer;white-space:nowrap">
        <input type="checkbox" id="phShowCancelled" onchange="renderPOHistory()"> แสดงที่ยกเลิกแล้ว
      </label>
      <button class="btn btn-outline" onclick="exportPOHistory()">⬇ Export CSV</button>
      <button class="btn btn-outline" style="color:#1557A0;border-color:#1557A0" onclick="exportPOJson()">💾 Export PO</button>
      <button class="btn btn-outline" style="color:#16A34A;border-color:#16A34A" onclick="document.getElementById('poImportFile2').click()">📂 Import PO</button>
      <input type="file" id="poImportFile2" accept=".json" style="display:none" onchange="importPOJson(this)">
      <button class="btn btn-outline" style="color:#16A34A;border-color:#16A34A" onclick="openRestorePO()">🔄 กู้คืน PO</button>
      <button class="btn" style="background:#EFF6FF;color:#1557A0;border:1px solid #BFDBFE" onclick="resetPOStatusCache()">🔄 รีเซ็ตสถานะ</button>
    </div>
    <div class="ph-body" id="phBody">
      <div style="text-align:center;color:var(--ink-lt);padding:40px">ยังไม่มีประวัติ PO</div>
    </div>
  </div>
</div>

<script>
// Auto-fill login
(function(){
  try {
    const s = JSON.parse(localStorage.getItem('vitoon_saved_login')||'null');
    if(s && s.u){
      document.getElementById('inputUser').value = s.u;
      document.getElementById('inputPass').value = s.p || '';
    }
  } catch(e){}
  // โหลด Users จาก Sheets ทันทีที่เปิดหน้า
  loadUsersFromSheets();
})();
</script>
</body>
</html>
