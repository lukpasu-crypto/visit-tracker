<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VITOON — ระบบสต็อกสินค้า</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root {
  --blue:    #1557A0;
  --blue-md: #1E7AC2;
  --blue-lt: #EBF4FF;
  --green:   #0E9E5A;
  --green-lt:#E6F7EF;
  --orange:  #D97706;
  --orange-lt:#FEF3C7;
  --red:     #DC2626;
  --red-lt:  #FEE2E2;
  --ink:     #0F1923;
  --ink-md:  #374151;
  --ink-lt:  #6B7280;
  --border:  #E5EBF2;
  --bg:      #F5F7FA;
  --white:   #FFFFFF;
  --shadow:  0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(0,0,0,.04);
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh}

.topbar{
  background:var(--blue);padding:0 32px;height:56px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;
  box-shadow:0 2px 12px rgba(21,87,160,.3);
}
.topbar-left{display:flex;align-items:center;gap:12px}
.topbar-logo{width:34px;height:34px;background:rgba(255,255,255,.15);border-radius:8px;display:grid;place-items:center;font-size:18px}
.topbar-title{color:#fff;font-size:16px;font-weight:700}
.topbar-sub{color:rgba(255,255,255,.6);font-size:12px;margin-left:4px}
.topbar-right{display:flex;align-items:center;gap:12px}
#lastUpdate{color:rgba(255,255,255,.65);font-size:12px;font-family:'IBM Plex Mono',monospace}
.btn-refresh{
  background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);
  color:#fff;padding:6px 16px;border-radius:6px;font-size:13px;
  font-family:'Sarabun',sans-serif;cursor:pointer;transition:.15s;
}
.btn-refresh:hover{background:rgba(255,255,255,.25)}
.btn-refresh:disabled{opacity:.5;cursor:default}

.main{padding:24px 32px;max-width:1400px;margin:0 auto}

/* Loading */
#loadingBar{
  height:3px;background:var(--blue-lt);
  position:fixed;top:56px;left:0;right:0;z-index:99;
  display:none;
}
#loadingBar .bar{
  height:100%;background:var(--blue-md);width:0;
  transition:width .3s;border-radius:0 2px 2px 0;
}

/* KPI */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:20px}
.kpi{
  background:var(--white);border-radius:12px;padding:18px 20px;
  box-shadow:var(--shadow);border-top:3px solid transparent;
  position:relative;overflow:hidden;transition:.2s;
}
.kpi:hover{transform:translateY(-1px)}
.kpi.blue{border-top-color:var(--blue)}
.kpi.green{border-top-color:var(--green)}
.kpi.orange{border-top-color:var(--orange)}
.kpi.red{border-top-color:var(--red)}
.kpi-icon{position:absolute;right:16px;top:16px;font-size:28px;opacity:.1}
.kpi-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--ink-lt);margin-bottom:6px}
.kpi-value{font-size:26px;font-weight:700;line-height:1;margin-bottom:4px}
.kpi.blue  .kpi-value{color:var(--blue)}
.kpi.green .kpi-value{color:var(--green)}
.kpi.orange .kpi-value{color:var(--orange)}
.kpi.red   .kpi-value{color:var(--red)}
.kpi-sub{font-size:12px;color:var(--ink-lt)}

/* Charts */
.mid-row{display:grid;grid-template-columns:1.6fr 1fr;gap:16px;margin-bottom:12px}
.card{background:var(--white);border-radius:12px;padding:10px 16px;box-shadow:var(--shadow)}
.card-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--ink-lt);margin-bottom:8px}

/* Toolbar */
.toolbar{
  background:var(--white);border-radius:12px;padding:14px 20px;
  box-shadow:var(--shadow);margin-bottom:16px;
  display:flex;align-items:center;gap:12px;flex-wrap:wrap;
}
.search-wrap{position:relative;flex:1;min-width:200px}
.search-wrap input{
  width:100%;padding:8px 12px 8px 36px;
  border:1px solid var(--border);border-radius:8px;
  font-size:14px;font-family:'Sarabun',sans-serif;
  background:var(--bg);transition:.15s;
}
.search-wrap input:focus{outline:none;border-color:var(--blue-md);background:#fff}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--ink-lt);font-size:16px;pointer-events:none}
select.filter{
  padding:8px 12px;border:1px solid var(--border);border-radius:8px;
  font-size:14px;font-family:'Sarabun',sans-serif;
  background:var(--bg);color:var(--ink);cursor:pointer;
}
select.filter:focus{outline:none;border-color:var(--blue-md)}
.btn{
  padding:8px 16px;border-radius:8px;font-size:13px;
  font-family:'Sarabun',sans-serif;font-weight:600;
  cursor:pointer;transition:.15s;border:none;
  display:flex;align-items:center;gap:6px;white-space:nowrap;
}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:var(--blue-md)}
.btn-outline{background:#fff;color:var(--ink-md);border:1px solid var(--border)}
.btn-outline:hover{border-color:var(--blue);color:var(--blue)}
#resultCount{font-size:13px;color:var(--ink-lt);white-space:nowrap}

/* Table */
.table-wrap{background:var(--white);border-radius:12px;box-shadow:var(--shadow);overflow:hidden}
.table-scroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:13px}
thead tr{background:var(--blue);color:#fff}
th{padding:8px 10px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;cursor:pointer;user-select:none}
th:hover{background:var(--blue-md)}
th .si{opacity:.5;margin-left:4px;font-size:10px}
th.sorted .si{opacity:1}
tbody tr{border-bottom:1px solid var(--border);transition:.1s}
tbody tr:hover{background:var(--blue-lt)}
tbody tr:last-child{border-bottom:none}
td{padding:8px 10px;vertical-align:middle}
td.mono{font-family:'IBM Plex Mono',monospace;font-size:11px;white-space:normal;word-break:break-all;max-width:90px}
td.num{text-align:right;font-family:'IBM Plex Mono',monospace;font-size:12px}
td.name{white-space:normal;word-break:break-word;font-size:13px;line-height:1.4;min-width:200px}

.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
.badge-ok    {background:var(--green-lt);color:var(--green)}
.badge-low   {background:var(--orange-lt);color:var(--orange)}
.badge-out   {background:var(--red-lt);color:var(--red)}
.badge-order {background:#EFF6FF;color:#1D4ED8;border:1px solid #BFDBFE}
.badge-nv    {background:#FFF0F0;color:#DC2626;border:1px solid #FECACA;font-weight:800}
.badge-A     {background:#FEF9C3;color:#92600A;border:1px solid #FDE047}
.badge-B     {background:#DBEAFE;color:#1E40AF;border:1px solid #BFDBFE}
.badge-C     {background:#F3F4F6;color:#6B7280;border:1px solid #E5E7EB}
.diff-up     {color:var(--red);font-weight:600}
.diff-down   {color:var(--green);font-weight:600}
.diff-zero   {color:var(--ink-lt)}

/* Pagination */
.pagination{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;border-top:1px solid var(--border)}
.page-info{font-size:13px;color:var(--ink-lt)}
.page-btns{display:flex;gap:6px}
.page-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:6px;background:#fff;cursor:pointer;font-size:13px;display:grid;place-items:center;transition:.1s}
.page-btn:hover{border-color:var(--blue);color:var(--blue)}
.page-btn.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.page-btn:disabled{opacity:.4;cursor:default}


.view-tabs{display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.view-tab{padding:8px 16px;border-radius:8px;font-size:13px;font-family:'Sarabun',sans-serif;font-weight:600;cursor:pointer;border:1px solid var(--border);background:#fff;color:var(--ink-md);transition:.15s}
.view-tab:hover{border-color:var(--blue);color:var(--blue)}
.view-tab.active{background:var(--blue);color:#fff;border-color:var(--blue)}
.view-tab.orange.active{background:var(--orange);border-color:var(--orange)}
.view-tab.red.active{background:var(--red);border-color:var(--red)}
.view-tab.gray.active{background:#6B7280;border-color:#6B7280}
.view-tab.blue.active{background:#1D4ED8;border-color:#1D4ED8}

/* Skeleton */
.skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.2s infinite;border-radius:6px;height:32px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

@media(max-width:900px){
  .kpi-row{grid-template-columns:repeat(2,1fr)}
  .mid-row{grid-template-columns:1fr}
  .main{padding:12px}
  .topbar{padding:0 12px;height:48px}
  .topbar-title{font-size:14px}
  .topbar-sub{display:none}
  #lastUpdate{display:none}
  .toolbar{flex-wrap:wrap;gap:6px}
  .search-wrap{width:100%}
  .view-tabs{gap:4px}
  .view-tab{padding:6px 10px;font-size:12px}
  td.name{white-space:normal;word-break:break-word;font-size:12px;width:40%}
  .col-hide-mobile{display:none}
  th.col-hide-mobile{display:none}
}
@media(max-width:600px){
  .kpi-row{grid-template-columns:repeat(2,1fr)}
  .kpi{padding:12px 14px}
  .kpi-value{font-size:20px}
  .topbar-right .btn-refresh:not(#btnPO):not([onclick="doLogout()"]){display:none!important}
  .mid-row{display:none}
}

/* ═══════════════════ LOGIN SCREEN ═══════════════════ */
#loginScreen{
  position:fixed;inset:0;background:linear-gradient(135deg,#0F1923 0%,#1557A0 100%);
  display:flex;align-items:center;justify-content:center;z-index:9999;
}
.login-box{
  background:#fff;border-radius:16px;padding:40px 36px;width:360px;
  box-shadow:0 20px 60px rgba(0,0,0,.4);text-align:center;
}
.login-logo{font-size:40px;margin-bottom:8px}
.login-title{font-size:20px;font-weight:700;color:var(--blue);margin-bottom:4px}
.login-sub{font-size:13px;color:var(--ink-lt);margin-bottom:28px}
.login-field{margin-bottom:14px;text-align:left}
.login-field label{font-size:13px;font-weight:600;color:var(--ink-md);display:block;margin-bottom:6px}
.login-field input{
  width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;
  font-size:14px;font-family:'Sarabun',sans-serif;outline:none;transition:.15s;
}
.login-field input:focus{border-color:var(--blue)}
.login-btn{
  width:100%;padding:12px;background:var(--blue);color:#fff;border:none;
  border-radius:8px;font-size:15px;font-weight:700;font-family:'Sarabun',sans-serif;
  cursor:pointer;margin-top:8px;transition:.15s;
}
.login-btn:hover{background:var(--blue-md)}
.login-error{
  color:var(--red);font-size:13px;margin-top:10px;display:none;
  background:var(--red-lt);padding:8px 12px;border-radius:6px;
}

/* ═══════════════════ LOG VIEWER ═══════════════════ */
#logModal{
  position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;
  display:none;align-items:center;justify-content:center;
}
.log-box{
  background:#fff;border-radius:12px;width:860px;max-width:95vw;
  max-height:80vh;display:flex;flex-direction:column;overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.3);
}
.log-header{
  padding:16px 20px;background:var(--blue);color:#fff;
  display:flex;align-items:center;justify-content:space-between;
}
.log-header h3{font-size:15px;font-weight:700}
.log-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer;line-height:1}
.log-body{overflow-y:auto;flex:1}
.log-body table{width:100%;border-collapse:collapse;font-size:13px}
.log-body th{background:#F5F7FA;padding:10px 14px;text-align:left;font-weight:600;color:var(--ink-md);border-bottom:1px solid var(--border);position:sticky;top:0}
.log-body td{padding:9px 14px;border-bottom:1px solid #F0F0F0;color:var(--ink)}
.log-body tr:hover td{background:#FAFBFF}
.log-footer{padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
.badge-login{background:#E6F7EF;color:#0E9E5A;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.badge-logout{background:#FEF3C7;color:#D97706;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.badge-export{background:#EBF4FF;color:#1557A0;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}


/* ═══════════════════ PO SYSTEM ═══════════════════ */
#poModal{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:8000;display:none;align-items:center;justify-content:center;}
.po-box{background:#fff;border-radius:12px;width:960px;max-width:96vw;max-height:90vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3);}
.po-header{padding:16px 20px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:space-between;}
.po-header h3{font-size:15px;font-weight:700}
.po-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer}
.po-body{padding:20px;overflow-y:auto;flex:1}
.po-section{margin-bottom:16px}
.po-section label{font-size:13px;font-weight:600;color:var(--ink-md);display:block;margin-bottom:6px}
.po-section input,.po-section select,.po-section textarea{
  width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;
  font-size:13px;font-family:'Sarabun',sans-serif;outline:none;transition:.15s;
}
.po-section input:focus,.po-section select:focus,.po-section textarea:focus{border-color:var(--blue)}
.po-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.po-items-table{width:100%;border-collapse:collapse;font-size:13px;margin-top:8px}
.po-items-table th{background:#F5F7FA;padding:9px 12px;text-align:left;font-weight:600;color:var(--ink-md);border-bottom:2px solid var(--border)}
.po-items-table td{padding:8px 12px;border-bottom:1px solid #F0F0F0}
.po-items-table td input{border:1px solid var(--border);border-radius:4px;padding:4px 8px;width:90px;font-size:13px;font-family:'Sarabun',sans-serif}
.po-items-table .del-btn{background:none;border:none;color:var(--red);cursor:pointer;font-size:16px;padding:2px 6px}
.po-total{text-align:right;font-size:15px;font-weight:700;color:var(--blue);padding:12px 0;border-top:2px solid var(--border);margin-top:8px}
.po-footer{padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;background:#FAFBFF}

/* Cart button in table */
.btn-cart{background:var(--blue-lt);border:1px solid var(--blue);color:var(--blue);
  padding:3px 10px;border-radius:5px;font-size:12px;font-weight:600;cursor:pointer;
  font-family:'Sarabun',sans-serif;transition:.15s;white-space:nowrap}
.btn-cart:hover{background:var(--blue);color:#fff}
.btn-cart.in-cart{background:var(--green);border-color:var(--green);color:#fff;font-weight:700}
.btn-cart.in-cart:hover{background:#0a8a4e}
.cart-badge{position:relative;display:inline-block}
.cart-count{position:absolute;top:-6px;right:-8px;background:var(--red);color:#fff;
  border-radius:50%;width:16px;height:16px;font-size:10px;display:flex;align-items:center;
  justify-content:center;font-weight:700}

/* Print */
@media print {
  body > *:not(#printArea){ display:none!important }
  #printArea{
    display:block!important;
    position:static!important;
    background:#fff;
    z-index:99999;
    padding:0;
    width:100%;
    overflow:visible!important;
    height:auto!important;
  }
  #printArea > div{ max-width:100%!important; padding:4mm 6mm!important; }
  table{ page-break-inside:auto; }
  tr{ page-break-inside:avoid; page-break-after:auto; }
  thead{ display:table-header-group; }
  tfoot{ display:table-footer-group; }
  .no-print{ display:none!important; }
}
@page{ size:A4; margin:6mm; }
#printArea{display:none}


/* ═══════════════════ WAREHOUSE MODAL ═══════════════════ */
#whModal{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:7000;display:none;align-items:center;justify-content:center;}
.wh-box{background:#fff;border-radius:12px;width:680px;max-width:95vw;max-height:85vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.25);}
.wh-header{padding:14px 18px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:space-between;}
.wh-header h3{font-size:14px;font-weight:700;line-height:1.4}
.wh-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer}
.wh-body{padding:18px;overflow-y:auto;flex:1}
.wh-table{width:100%;border-collapse:collapse;font-size:13px}
.wh-table th{background:#F5F7FA;padding:9px 12px;text-align:left;font-weight:600;color:var(--ink-md);border-bottom:2px solid var(--border)}
.wh-table td{padding:8px 12px;border-bottom:1px solid #F5F5F5}
.wh-table tr:hover td{background:#FAFBFF}
.wh-bar-wrap{background:#E5EBF2;border-radius:4px;height:8px;width:100%;min-width:80px}
.wh-bar{height:8px;border-radius:4px;background:var(--blue);transition:.3s}
.wh-total{font-size:13px;font-weight:700;color:var(--blue);margin-top:12px;text-align:right;padding-top:10px;border-top:2px solid var(--border)}
.wh-empty{text-align:center;padding:30px;color:var(--ink-lt);font-size:13px}
.btn-wh{background:none;border:1.5px solid var(--blue-md);color:var(--blue);
  width:26px;height:26px;border-radius:5px;font-size:16px;font-weight:700;
  cursor:pointer;font-family:'Sarabun',sans-serif;display:inline-flex;align-items:center;justify-content:center;line-height:1}
.btn-wh:hover{background:var(--blue-lt)}


/* ═══════════════════ USER MANAGEMENT ═══════════════════ */
#userMgmtModal{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;display:none;align-items:center;justify-content:center;}
.um-box{background:#fff;border-radius:12px;width:680px;max-width:95vw;max-height:88vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.3);}
.um-header{padding:14px 18px;background:var(--blue);color:#fff;display:flex;align-items:center;justify-content:space-between;}
.um-header h3{font-size:14px;font-weight:700}
.um-close{background:none;border:none;color:#fff;font-size:20px;cursor:pointer}
.um-body{padding:18px;overflow-y:auto;flex:1}
.um-table{width:100%;border-collapse:collapse;font-size:13px;margin-bottom:16px}
.um-table th{background:#F5F7FA;padding:9px 12px;text-align:left;font-weight:600;color:var(--ink-md);border-bottom:2px solid var(--border)}
.um-table td{padding:8px 12px;border-bottom:1px solid #F0F0F0;vertical-align:middle}
.um-table tr:hover td{background:#FAFBFF}
.um-form{background:#F5F7FA;border-radius:8px;padding:14px;margin-top:8px}
.um-form-title{font-size:13px;font-weight:700;color:var(--blue);margin-bottom:10px}
.um-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.um-field label{font-size:12px;font-weight:600;color:var(--ink-md);display:block;margin-bottom:4px}
.um-field input,.um-field select{width:100%;padding:8px 10px;border:1.5px solid var(--border);border-radius:6px;font-size:13px;font-family:'Sarabun',sans-serif;outline:none}
.um-field input:focus,.um-field select:focus{border-color:var(--blue)}
.btn-del-user{background:none;border:1px solid var(--red);color:var(--red);padding:3px 9px;border-radius:5px;font-size:11px;cursor:pointer;font-family:'Sarabun',sans-serif}
.btn-del-user:hover{background:var(--red-lt)}
.btn-edit-user{background:none;border:1px solid var(--blue);color:var(--blue);padding:3px 9px;border-radius:5px;font-size:11px;cursor:pointer;font-family:'Sarabun',sans-serif}
.btn-edit-user:hover{background:var(--blue-lt)}
.role-badge{padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.role-admin{background:#EBF4FF;color:var(--blue)}
.role-manager{background:#E6F7EF;color:var(--green)}
.role-staff{background:#FEF3C7;color:var(--orange)}


/* Column Toggle */
.col-toggle-bar{background:#fff;border-radius:10px;padding:10px 16px;margin-bottom:8px;box-shadow:var(--shadow);display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.col-toggle-bar label{display:flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--ink-md);cursor:pointer;user-select:none;white-space:nowrap}
.col-toggle-bar input[type=checkbox]{width:14px;height:14px;cursor:pointer;accent-color:var(--blue)}
.col-toggle-title{font-size:12px;font-weight:700;color:var(--ink-lt);text-transform:uppercase;letter-spacing:.5px;margin-right:4px}


/* PO History Modal */
#poHistoryModal{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:3000;display:none;align-items:center;justify-content:center}
.ph-box{background:#fff;border-radius:16px;width:min(95vw,900px);max-height:90vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.ph-header{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ph-header h3{font-size:16px;font-weight:700;color:var(--blue)}
.ph-close{background:none;border:none;font-size:20px;cursor:pointer;color:var(--ink-lt)}
.ph-toolbar{padding:12px 20px;border-bottom:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap}
.ph-toolbar input{flex:1;min-width:200px;padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-size:13px;font-family:Sarabun,sans-serif}
.ph-body{overflow-y:auto;padding:16px 20px;flex:1}
.ph-card{border:1px solid var(--border);border-radius:10px;margin-bottom:12px;overflow:hidden;cursor:pointer;transition:.15s}
.ph-card:hover{border-color:var(--blue);box-shadow:0 2px 8px rgba(21,87,160,.1)}
.ph-card-head{padding:12px 16px;background:#F8FAFF;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.ph-card-body{padding:12px 16px;display:none;border-top:1px solid var(--border)}
.ph-card.open .ph-card-body{display:block}
.ph-no{font-weight:700;color:var(--blue);font-size:14px}
.ph-meta{font-size:12px;color:var(--ink-lt)}
.ph-total{font-weight:700;color:var(--green);font-size:14px}
.ph-items-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
.ph-items-table th{background:var(--blue);color:#fff;padding:6px 10px;text-align:left}
.ph-items-table td{padding:6px 10px;border-bottom:1px solid var(--border)}
.ph-drive-link{display:inline-flex;align-items:center;gap:4px;font-size:12px;color:var(--blue);text-decoration:none;padding:4px 10px;border:1px solid var(--blue);border-radius:6px;margin-top:8px}
.ph-drive-link:hover{background:var(--blue-lt)}


/* Autocomplete */
.ac-wrap{position:relative}
.ac-list{position:absolute;top:100%;left:0;right:0;background:#fff;border:1.5px solid var(--blue);border-top:none;border-radius:0 0 8px 8px;z-index:9999;max-height:200px;overflow-y:auto;box-shadow:0 4px 12px rgba(0,0,0,.15);display:none}
.ac-list.show{display:block}
.ac-item{padding:8px 14px;font-size:13px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:.1s}
.ac-item:hover,.ac-item.active{background:var(--blue-lt);color:var(--blue)}
.ac-item-name{font-weight:600}
.ac-item-sub{font-size:11px;color:var(--ink-lt)}
.ac-item-del{font-size:11px;color:#ccc;padding:2px 6px;border-radius:4px}
.ac-item-del:hover{background:#fee2e2;color:var(--red)}


/* PO Status Icon + Tooltip */
.po-status-wrap{position:relative;display:inline-block;cursor:pointer}
.po-status-icon{font-size:16px;line-height:1}
.po-tooltip{
  display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);
  background:#1E293B;color:#fff;border-radius:8px;padding:8px 12px;
  font-size:12px;white-space:nowrap;z-index:9999;min-width:180px;
  box-shadow:0 4px 12px rgba(0,0,0,.3);font-family:Sarabun,sans-serif;
  pointer-events:none;
}
.po-tooltip::after{
  content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);
  border:5px solid transparent;border-top-color:#1E293B;
}
.po-status-wrap:hover .po-tooltip{display:block}
.po-tooltip-row{display:flex;justify-content:space-between;gap:16px;margin-bottom:4px}
.po-tooltip-row:last-child{margin-bottom:0}
.po-tooltip-label{color:#94A3B8;font-size:11px}
.po-tooltip-val{color:#fff;font-weight:600;font-size:11px}

</style>
</head>
<body>

<div id="loadingBar"><div class="bar" id="bar"></div></div>

<div class="topbar">
  <div class="topbar-left">
    <div class="topbar-logo">❄️</div>
    <div>
      <span class="topbar-title">VITOON</span>
      <span class="topbar-sub">ระบบรายงานสต็อกสินค้า</span>
    </div>
  </div>
  <div class="topbar-right">
    <span id="userBadge" style="color:rgba(255,255,255,.8);font-size:13px;font-weight:600"></span>
    <button class="btn-refresh" id="btnLog" onclick="openLog()" style="display:none">📋 Log</button>
    <button class="btn-refresh" id="btnPOHistory" onclick="openPOHistory()">📄 ประวัติ PO</button>
    <button class="btn-refresh cart-badge" id="btnPO" onclick="openPO()"><span>🛒 สั่งซื้อ</span><span class="cart-count" id="cartCount" style="display:none">0</span></button>
    <button class="btn-refresh" id="btnUserMgmt" onclick="openUserMgmt()" style="display:none">👥 จัดการ User</button>
    <button class="btn-refresh" onclick="doLogout()">ออกจากระบบ</button>
    <span id="lastUpdate">กำลังโหลด...</span>
    <button class="btn-refresh" id="btnRefresh" onclick="manualRefresh()">🔄 อัปเดต</button>
  </div>
</div>

<div class="main">
  <!-- KPI -->
  <div class="kpi-row">
    <div class="kpi blue"><div class="kpi-icon">💰</div><div class="kpi-label">มูลค่าสต็อกรวม</div><div class="kpi-value" id="kpi1">—</div><div class="kpi-sub" id="kpi1s">—</div></div>
    <div class="kpi green"><div class="kpi-icon">✅</div><div class="kpi-label">สินค้าปกติ</div><div class="kpi-value" id="kpi2">—</div><div class="kpi-sub" id="kpi2s">—</div></div>
    <div class="kpi orange"><div class="kpi-icon">⚠️</div><div class="kpi-label">ใกล้หมด</div><div class="kpi-value" id="kpi3">—</div><div class="kpi-sub" id="kpi3s">QtyOnHand 1–5</div></div>
    <div class="kpi red"><div class="kpi-icon">🚨</div><div class="kpi-label">หมดสต็อก</div><div class="kpi-value" id="kpi4">—</div><div class="kpi-sub" id="kpi4s">QtyOnHand = 0</div></div>
  </div>

  <!-- Charts -->
  <div class="mid-row">
    <div class="card">
      <div class="card-title">มูลค่าสต็อกตามหมวดหมู่</div>
      <canvas id="catChart" height="100"></canvas>
    </div>
    <div class="card" style="display:flex;flex-direction:column;align-items:center">
      <div class="card-title" style="width:100%">ABC Classification</div>
      <div style="width:220px;height:220px"><canvas id="abcChart"></canvas></div>
    </div>
  </div>

  <!-- View Mode Tabs -->
  <div class="view-tabs">
    <button class="view-tab active" id="tab_normal" onclick="setViewMode('normal')">สต็อกคงเหลือ</button>
    <button class="view-tab orange" id="tab_order" onclick="setViewMode('order')">ใกล้หมด + ติดลบ (สั่งซื้อ)</button>
    <button class="view-tab red" id="tab_zero" onclick="setViewMode('zero')">หมดสต็อก (QtyOnHand=0)</button>
    <button class="view-tab blue" id="tab_po" onclick="setViewMode('po')">🔵 รอสั่งซื้อ</button>
    <button class="view-tab gray" id="tab_all" onclick="setViewMode('all')">ทั้งหมด</button>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" id="searchInput" placeholder="ค้นหาชื่อสินค้า หรือรหัสสินค้า..." oninput="applyFilters()">
    </div>
    <select class="filter" id="filterCat" onchange="applyFilters()"><option value="">— ทุกหมวดหมู่ —</option></select>
    <select class="filter" id="filterABC" onchange="applyFilters()">
      <option value="">— ทุก ABC —</option>
      <option value="A">Class A</option>
      <option value="B">Class B</option>
      <option value="C">Class C</option>
    </select>
    <span id="resultCount">— รายการ</span>
    <button class="btn btn-outline" onclick="clearFilters()">↺ ล้าง</button>
    <button class="btn btn-primary" onclick="exportCSV()">⬇ Export</button>
  </div>

  <!-- Column Toggle -->
  <div class="col-toggle-bar" style="display:none">
    <span class="col-toggle-title">แสดงคอลัมน์:</span>
    
    <label><input type="checkbox" id="col_diff" checked onchange="toggleCol()"> ส่วนต่าง%</label>
    <label><input type="checkbox" id="col_value" checked onchange="toggleCol()"> มูลค่ารวม</label>
    <label><input type="checkbox" id="col_abc" checked onchange="toggleCol()"> ABC</label>
  </div>

  <!-- Table -->
  <div class="table-wrap">
    <div class="table-scroll">
      <table>
        <thead><tr>
          <th onclick="sortBy('ProductCode')" data-col="ProductCode">รหัส <span class="si">↕</span></th>
          <th onclick="sortBy('ProductName')" data-col="ProductName">ชื่อสินค้า <span class="si">↕</span></th>
          <th onclick="sortBy('MainCatName')" data-col="MainCatName" class="col-hide-mobile">หมวดหมู่ <span class="si">↕</span></th>
          <th onclick="sortBy('QtyOnHand')" data-col="QtyOnHand">คงเหลือ <span class="si">↕</span></th>
          <th id="th_cost" style="display:none"></th>
          <th onclick="sortBy('LastPurchasePrice')" data-col="LastPurchasePrice">ซื้อล่าสุด <span class="si">↕</span></th>
          <th onclick="sortBy('LastPurchaseDate')" data-col="LastPurchaseDate">วันที่ซื้อ <span class="si">↕</span></th>
          <th id="th_diff" style="display:none"></th>
          <th id="th_value" style="display:none"></th>
          <th onclick="sortBy('StockStatus')" data-col="StockStatus">สถานะ <span class="si">↕</span></th>
          <th id="th_abc" style="display:none"></th>
          <th></th>
        </tr></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
    <div class="pagination">
      <div class="page-info" id="pageInfo">—</div>
      <div class="page-btns" id="pageBtns"></div>
    </div>
  </div>
</div>

<script>
// ═══════════════════════════════════
//  CONFIG
// ═══════════════════════════════════
const API_KEY   = 'AIzaSyArrq4vw2fGwKWPZuPGsfNny4cj8A1RWDo';
const PO_API    = 'https://script.google.com/macros/s/AKfycbyiSLGhjt_3igPl9BTATrX68EGURiHaaz96RFk9Sh6OypORR7aBW3rw3jBBF-jyKFyg/exec';
const PO_SECRET = 'vitoon2024';
const SHEET_ID  = '1x7VuEQ0w2FcMuol1L7l89LcjrZ6oVOV_VIUreoSxyXU';
const SHEET_TAB = 'stock_vitoon';

// ═══════════════════════════════════
//  STATE
// ═══════════════════════════════════
let allData=[], filtered=[], sortCol='ProductCode', sortAsc=true, currentPage=1;
let viewMode='normal'; // normal | order | zero | all
const PAGE=50;
let catChart=null, abcChart=null;

// ═══════════════════════════════════
//  LOAD FROM GOOGLE SHEETS
// ═══════════════════════════════════
async function loadData(){
  const btn=document.getElementById('btnRefresh');
  btn.disabled=true; btn.textContent='กำลังโหลด...';
  showBar(20);
  try {
    const url=`https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${encodeURIComponent(SHEET_TAB)}?key=${API_KEY}`;
    const res=await fetch(url);
    if(!res.ok) throw new Error('HTTP '+res.status);
    const json=await res.json();
    showBar(60);
    const rows=json.values||[];
    if(rows.length<2) throw new Error('ไม่มีข้อมูล');
    const headers=rows[0];
    allData=rows.slice(1).map(r=>{
      const obj={};
      headers.forEach((h,i)=>{ obj[h]=(r[i]||'').trim(); });
      ['QtyOnHand','StdCostPrice','LastPurchasePrice','PriceDiff','PriceDiffPct','TotalStdValue','TotalBuyValue',
       'LastPurchasePriceBeforeDisc','LastPurchaseDiscAmnt']
        .forEach(k=>{ obj[k]=parseFloat(obj[k])||0; });
      return obj;
    }).filter(r=>r.ProductCode);
    showBar(90);
    buildCatFilter();
    applyFilters();
    renderCharts();
    document.getElementById('lastUpdate').textContent='อัปเดต: '+new Date().toLocaleString('th-TH',{hour12:false})+' | '+SHEET_TAB;
    showBar(100);
  } catch(e){
    document.getElementById('lastUpdate').textContent='โหลดไม่สำเร็จ: '+e.message;
    console.error(e);
  } finally {
    btn.disabled=false; btn.textContent='🔄 รีเฟรช';
    setTimeout(()=>{ document.getElementById('loadingBar').style.display='none'; },400);
  }
}

function showBar(pct){
  const lb=document.getElementById('loadingBar');
  lb.style.display='block';
  document.getElementById('bar').style.width=pct+'%';
}

// ═══════════════════════════════════
//  FILTERS
// ═══════════════════════════════════
function buildCatFilter(){
  const sel=document.getElementById('filterCat');
  const current=sel.value; // จำค่าที่เลือกไว้
  sel.innerHTML='<option value="">— ทุกหมวดหมู่ —</option>';
  // นับจาก allData สำหรับ list รายการ
  const cats=[...new Set(allData.map(r=>r.MainCatName).filter(Boolean))].sort();
  cats.forEach(c=>{
    const o=document.createElement('option');
    o.value=c;
    o.textContent=c;
    sel.appendChild(o);
  });
  sel.value=current; // คืนค่าที่เลือก
  updateCatCount(); // อัปเดตยอดตาม filtered
}

function updateCatCount(){
  const sel=document.getElementById('filterCat');
  // นับจาก filtered (ตาม viewMode ปัจจุบัน) แต่ไม่กรอง cat
  const base=allData.filter(r=>{
    if(viewMode==='normal' && r.QtyOnHand<=0) return false;
    if(viewMode==='order'  && r.QtyOnHand>=0 && r.StockStatus==='ปกติ') return false;
    if(viewMode==='order'  && r.QtyOnHand>5)  return false;
    if(viewMode==='zero'   && r.QtyOnHand!==0) return false;
    if(viewMode==='po'){
      const poMap = getPOStatusMap();
      if(!poMap[r.ProductCode] || !poMap[r.ProductCode].length) return false;
    }
    return true;
  });
  const catCount={};
  base.forEach(r=>{ if(r.MainCatName) catCount[r.MainCatName]=(catCount[r.MainCatName]||0)+1; });
  Array.from(sel.options).forEach(o=>{
    if(!o.value) { o.textContent='— ทุกหมวดหมู่ —'; return; }
    const n=catCount[o.value]||0;
    o.textContent=o.value + ' (' + n + ')';
  });
}

function setViewMode(mode){
  viewMode=mode;
  ['normal','order','zero','po','all'].forEach(m=>{
    const t=document.getElementById('tab_'+m);
    if(t) t.classList.toggle('active', m===mode);
  });
  applyFilters();
}


function applyFilters(){
  const s=document.getElementById('searchInput').value.toLowerCase().trim();
  const cat=document.getElementById('filterCat').value;
  const abc=document.getElementById('filterABC').value;
  filtered=allData.filter(r=>{
    // -- View Mode filter --
    if(viewMode==='normal' && r.QtyOnHand<=0) return false;     // เฉพาะ > 0
    if(viewMode==='order'  && r.QtyOnHand>=0 && r.StockStatus==='ปกติ') return false; // ติดลบ + ใกล้หมด
    if(viewMode==='order'  && r.QtyOnHand>5)  return false;     // ตัด qty > 5 ออก
    if(viewMode==='zero'   && r.QtyOnHand!==0) return false;    // เฉพาะ = 0
    if(viewMode==='po'){                                         // เฉพาะที่มี PO active
      const poMap = getPOStatusMap();
      if(!poMap[r.ProductCode] || !poMap[r.ProductCode].length) return false;
    }
    // viewMode==='all' ไม่ filter qty
    // -- Search & filters --
    if(s && !r.ProductCode.toLowerCase().includes(s) && !r.ProductName.toLowerCase().includes(s)) return false;
    if(cat && r.MainCatName!==cat) return false;
    if(abc && r.ABC_Class!==abc)   return false;
    return true;
  });
  sortData(); updateKPI(); currentPage=1; renderTable(); updateCatCount();
}

function clearFilters(){
  document.getElementById('searchInput').value='';
  document.getElementById('filterCat').value='';
  document.getElementById('filterABC').value='';
  applyFilters();
}

// ═══════════════════════════════════
//  SORT
// ═══════════════════════════════════
function sortBy(col){
  if(sortCol===col) sortAsc=!sortAsc; else{sortCol=col;sortAsc=false;}
  document.querySelectorAll('th').forEach(th=>{th.classList.remove('sorted');th.querySelector('.si').textContent='↕'});
  const th=document.querySelector(`th[data-col="${col}"]`);
  if(th){th.classList.add('sorted');th.querySelector('.si').textContent=sortAsc?'↑':'↓';}
  sortData(); currentPage=1; renderTable();
}
function sortData(){
  const num=['QtyOnHand','StdCostPrice','LastPurchasePrice','PriceDiffPct','TotalStdValue'];
  filtered.sort((a,b)=>{
    let va=a[sortCol],vb=b[sortCol];
    if(num.includes(sortCol)){va=+va||0;vb=+vb||0;}
    else{va=(va||'').toString();vb=(vb||'').toString();}
    return va<vb?(sortAsc?-1:1):va>vb?(sortAsc?1:-1):0;
  });
}

// ═══════════════════════════════════
//  KPI
// ═══════════════════════════════════
function updateKPI(){
  // มูลค่าสต็อกรวม คำนวณจาก allData ทั้งหมด ไม่ขึ้นกับ filter ตาราง
  const totalAll   = allData.reduce((s,r)=>s+(r.QtyOnHand>0?r.QtyOnHand*(r.LastPurchasePrice||0):0),0);
  const totalStock = allData.filter(r=>r.QtyOnHand>0).reduce((s,r)=>s+r.QtyOnHand*(r.LastPurchasePrice||0),0);
  const nAll   = allData.length;
  const nStock = allData.filter(r=>r.QtyOnHand>0).length;

  const isAllMode = (viewMode === 'all');
  document.getElementById('kpi1').textContent = fmtMoney(isAllMode ? totalAll : totalStock);
  document.getElementById('kpi1s').textContent = (isAllMode ? 'ทั้งหมด ' + nAll.toLocaleString() : 'คงเหลือ ' + nStock.toLocaleString()) + ' รายการ';

  const n   = allData.length;
  const ok  = allData.filter(r=>r.StockStatus==='ปกติ').length;
  const low = allData.filter(r=>r.StockStatus==='ใกล้หมด').length;
  const out = allData.filter(r=>r.StockStatus==='หมดสต็อก').length;
  document.getElementById('kpi2').textContent=ok.toLocaleString();
  document.getElementById('kpi2s').textContent=Math.round(ok/n*100||0)+'% ของทั้งหมด';
  document.getElementById('kpi3').textContent=low.toLocaleString();
  document.getElementById('kpi4').textContent=out.toLocaleString();
}

// ═══════════════════════════════════
//  TABLE
// ═══════════════════════════════════
function renderTable(){
  const total=filtered.length, pages=Math.ceil(total/PAGE)||1;
  if(currentPage>pages) currentPage=pages;
  const start=(currentPage-1)*PAGE;
  const slice=filtered.slice(start,start+PAGE);
  document.getElementById('resultCount').textContent=total.toLocaleString()+' รายการ';
  document.getElementById('pageInfo').textContent=`แสดง ${start+1}–${Math.min(start+PAGE,total)} จาก ${total.toLocaleString()} รายการ`;
  const tbody=document.getElementById('tableBody');
  if(!slice.length){tbody.innerHTML=`<tr><td colspan="10" style="text-align:center;padding:40px;color:#9ca3af">ไม่พบรายการที่ค้นหา</td></tr>`;renderPagination(0,1);return;}
  tbody.innerHTML=slice.map((r,i)=>{
    const dp=r.PriceDiffPct, dc=dp>0?'diff-up':dp<0?'diff-down':'diff-zero', dt=dp===0?'—':(dp>0?'+':'')+dp.toFixed(1)+'%';
    const isNV = /NV$|\(NV\)|#NV/i.test(r.ProductCode||'');
    const qtyColor = r.QtyOnHand<0 ? 'color:var(--red);font-weight:700'
                   : r.QtyOnHand===0 ? 'color:var(--ink-lt)'
                   : r.QtyOnHand<=5  ? 'color:var(--orange);font-weight:700'
                   : 'color:var(--green);font-weight:700';
    const poMap = getPOStatusMap();
    const poItems = poMap[r.ProductCode];
    const hasActivePO = poItems && poItems.length > 0;
    const poQty = hasActivePO ? poItems.reduce((s,p)=>s+p.qty,0) : 0;
    const poNos = hasActivePO ? poItems.map(p=>p.poNo).join(', ') : '';

    // ตรวจว่าของเข้าแล้วทุกรายการหรือยัง
    const allReceived = hasActivePO && poItems.every(p => p.received);
    const someReceived = hasActivePO && !allReceived && poItems.some(p => p.received);

    let sb, statusText;
    if(hasActivePO){
      if(allReceived){
        sb = 'badge-ok'; statusText = '✅ รับของแล้ว';
      } else if(someReceived){
        sb = 'badge-order'; statusText = '🟡 รับบางส่วน';
      } else {
        sb = 'badge-order'; statusText = '🔵 สั่งซื้อแล้ว';
      }
    } else {
      sb = r.StockStatus==='ปกติ'?'badge-ok':r.StockStatus==='ใกล้หมด'?'badge-low':'badge-out';
      statusText = r.StockStatus||'—';
    }

    // icon สำหรับ tooltip
