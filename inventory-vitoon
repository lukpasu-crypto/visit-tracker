function getNextPONumber(){
  const year = new Date().getFullYear();
  const records = getPORecords();
  // หาเลข seq สูงสุดของปีนี้
  let maxSeq = 0;
  records.forEach(r => {
    if(!r.poNo) return;
    const m = r.poNo.match(/^PO-(\d{4})-(\d+)$/);
    if(m && parseInt(m[1]) === year){
      maxSeq = Math.max(maxSeq, parseInt(m[2]));
    }
  });
  return `PO-${year}-${String(maxSeq + 1).padStart(4, '0')}`;
}


