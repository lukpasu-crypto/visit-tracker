async function showWarehouse(item){
  document.getElementById('whTitle').textContent = `📦 คลัง: ${item.ProductCode} — ${item.ProductName}`;
  document.getElementById('whBody').innerHTML = '<div class="wh-empty">⏳ กำลังโหลดข้อมูลคลัง...</div>';
  document.getElementById('whModal').style.display = 'flex';

  await loadWarehouseData();

  // filter by GoodID or ProductCode
  const rows = whData.filter(r =>
    String(r.GoodID) === String(item.GoodID) ||
    r.ProductCode === item.ProductCode
  );

  if(!rows.length){
    document.getElementById('whBody').innerHTML = '<div class="wh-empty">ไม่พบข้อมูลคลังสำหรับสินค้านี้<br><small>กรุณารัน uploader ใหม่เพื่ออัปเดตข้อมูลคลัง</small></div>';
    return;
  }

  const total = rows.reduce((s, r) => s + (parseFloat(r.QtyOnHand)||0), 0);
  const maxQty = Math.max(...rows.map(r => parseFloat(r.QtyOnHand)||0));

  const tableRows = rows.map(r => {
    const qty = parseFloat(r.QtyOnHand)||0;
    const pct = maxQty > 0 ? Math.round(qty/maxQty*100) : 0;
    const qtyColor = qty < 0 ? 'color:var(--red);font-weight:700' : qty === 0 ? 'color:var(--ink-lt)' : 'font-weight:600';
    return `<tr style="${isNV ? 'background:#FFF0F0;color:#DC2626' : ''}">
      <td><b>${esc(r.WarehouseName||'—')}</b></td>
      <td style="color:var(--ink-lt);font-size:12px">${esc(r.WarehouseCode||'—')}</td>
      <td style="${qtyColor}">${fmtNum(qty)}</td>
      <td style="width:120px">
        <div class="wh-bar-wrap"><div class="wh-bar" style="width:${pct}%"></div></div>
      </td>
    </tr>`;
  }).join('');

  document.getElementById('whBody').innerHTML = `
    <table class="wh-table">
      <thead><tr>
        <th>คลัง / ชั้นเก็บของ</th>
        <th>รหัสคลัง</th>
        <th>ยอดคงเหลือ</th>
        <th>สัดส่วน</th>
      </tr></thead>
      <tbody>${tableRows}</tbody>
    </table>
    <div class="wh-total">รวมทั้งหมด: ${fmtNum(total)} หน่วย</div>
  `;
}


