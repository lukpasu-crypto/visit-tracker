function importPOJson(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const data = JSON.parse(e.target.result);
      if(!Array.isArray(data)) throw new Error('รูปแบบไฟล์ไม่ถูกต้อง');
      const existing = getPORecords();
      // merge — ถ้า poNo ซ้ำ ให้ข้ามไม่ overwrite
      let added = 0;
      data.forEach(r => {
        if(!r.poNo) return;
        if(!existing.find(e => e.poNo === r.poNo)){
          existing.unshift(r);
          added++;
        }
      });
      existing.sort((a,b) => (b.poNo||'').localeCompare(a.poNo||''));
      localStorage.setItem('vitoon_po_records', JSON.stringify(existing.slice(0,200)));
      renderPOHistory();
      alert('✅ Import สำเร็จ\nเพิ่ม ' + added + ' ใบ | ซ้ำ ' + (data.length - added) + ' ใบ (ไม่ overwrite)');
    } catch(err) {
      alert('❌ ไฟล์ผิดพลาด: ' + err.message);
    }
    input.value = '';
  };
  reader.readAsText(file);
}

function exportPOHistory(){
  const records = getPORecords();
  if(!records.length){ alert('ไม่มีข้อมูล PO'); return; }
  const headers = ['PO_Number','Date','Supplier','Contact','Creator','ProductCode','ProductName','Qty','UnitPrice','Total','VAT%','SubTotal','VATAmt','GrandTotal','Remark','CreatedAt','DriveURL'];
  const rows = [];
  records.forEach(r => {
    (r.items||[]).forEach(it => {
      const ep = it.customPrice !== undefined ? it.customPrice : it.LastPurchasePrice;
      rows.push([r.poNo, r.poDate, r.supplier||'', r.contact||'', r.creator||'',
        it.ProductCode, it.ProductName, it.qty, ep, it.qty*(ep||0),
        (r.vatMode||0)+'%', r.subtotal||0, r.vatAmt||0, r.total||0,
        r.remark||'', r.createdAt||'', r.driveUrl||'']);
    });
  });
  const csv = [headers, ...rows].map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'}));
  a.download = 'VITOON_PO_History.csv';
  a.click();
}

async function clearAllPORecords(){
  const records = getPORecords();
  if(!confirm(`⚠️ ยืนยันเคลียร์ประวัติ PO ทั้งหมด${records.length ? ' ' + records.length + ' รายการ' : ''}?\n\nจะลบออกทั้งจากเครื่องและ Google Sheets\nเลข PO จะเริ่มนับใหม่\n\n${records.length ? 'แนะนำ Export CSV ก่อนเคลียร์' : ''}`)) return;

  // 1. ล้าง localStorage ทันที
  localStorage.removeItem('vitoon_po_records');
  // เก็บ timestamp ที่เคลียร์ เพื่อป้องกัน loadPOFromSheets ดึงมา overwrite
  localStorage.setItem('vitoon_po_cleared_at', Date.now().toString());

  renderPOHistory();
  renderTable(); // refresh ตารางหลัก — สถานะ 🔵 จะหายทันที
  const poNumEl = document.getElementById('poNumber');
  if(poNumEl && poNumEl.value) poNumEl.value = getNextPONumber();

  // 2. ส่งคำสั่งลบไป Google Sheets API
  showSyncStatus('🗑 กำลังลบข้อมูลใน Sheets...');
  try {
    const res = await fetch(PO_API, {
      method: 'POST',
      headers: {'Content-Type':'text/plain'},
      body: JSON.stringify({ secret: PO_SECRET, action: 'clear_all' })
    });
    const data = await res.json();
    if(data.ok){
