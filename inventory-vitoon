function updateQty(i, val){
  cart[i].qty = Math.max(1, parseInt(val)||1);
  if(priceMode !== 'none'){
    const ep = cart[i].customPrice !== undefined ? cart[i].customPrice : cart[i].LastPurchasePrice;
    const el = document.getElementById('rowTotal'+i);
    if(el) el.textContent = fmtMoney(cart[i].qty * ep);
  }
  updatePOTotal();
}

function updatePrice(i, val){
  cart[i].customPrice = parseFloat(val)||0;
  const el = document.getElementById('rowTotal'+i);
  if(el) el.textContent = fmtMoney(cart[i].qty * cart[i].customPrice);
  updatePOTotal();
}

function updateName(i, val){
  cart[i].ProductName = val;
}

function updateRemark(i, val){
  cart[i].remark = val;
}

function updateUnit(i, val){
