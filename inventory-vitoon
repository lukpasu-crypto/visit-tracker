function getSuppliers(){
  try { return JSON.parse(localStorage.getItem('vitoon_suppliers')||'[]'); }
  catch(e){ return []; }
}

function saveSupplier(supplier, contact){
  if(!supplier.trim()) return;
  const list = getSuppliers();
  // หาว่ามีอยู่แล้วไหม
  const idx = list.findIndex(s => s.name.toLowerCase() === supplier.trim().toLowerCase());
  if(idx >= 0){
    // อัปเดตข้อมูล contact
    if(contact && !list[idx].contacts.includes(contact.trim())){
      list[idx].contacts.unshift(contact.trim());
      list[idx].contacts = list[idx].contacts.slice(0,5);
    }
    // เลื่อนขึ้นมาด้านบน (ใช้บ่อย)
    const [item] = list.splice(idx,1);
    list.unshift(item);
  } else {
    list.unshift({
      name: supplier.trim(),
      contacts: contact ? [contact.trim()] : []
    });
  }
  localStorage.setItem('vitoon_suppliers', JSON.stringify(list.slice(0,100)));
}

function deleteSupplier(name, e){
  e.stopPropagation();
  const list = getSuppliers().filter(s => s.name !== name);
  localStorage.setItem('vitoon_suppliers', JSON.stringify(list));
  acShow('poSupplier','acSupplier');
}

