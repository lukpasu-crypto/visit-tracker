function findNVPair(productCode){
  // หาคู่ NV: ถ้า item เป็นรหัสปกติ → หา NV; ถ้า item เป็น NV → หา base
  const code = productCode || '';
  const isNV = /NV$|\(NV\)|#NV/i.test(code);
  let pairs = [];
  if(!isNV){
    // หาสินค้าที่ base code เดียวกัน แต่ลงท้าย NV
    const base = code.replace(/[\s_-]*(NV|\(NV\)|#NV)\s*$/i,'').trim();
    pairs = allData.filter(r => {
      const rc = r.ProductCode||'';
      if(rc === code) return false;
      const rcBase = rc.replace(/[\s_-]*(NV|\(NV\)|#NV)\s*$/i,'').trim();
      return rcBase === base && /NV$|\(NV\)|#NV/i.test(rc);
    });
  }
  return pairs;
}

