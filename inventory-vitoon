function editUser(i){
  umEditIndex = i;
  const u = USERS[i];
  document.getElementById('umUsername').value = u.username;
  document.getElementById('umName').value     = u.name;
  document.getElementById('umPassword').value = u.password;
  document.getElementById('umRole').value     = u.role;
  document.getElementById('umFormTitle').textContent = `✏️ แก้ไข: ${u.username}`;
  document.getElementById('umUsername').disabled = true;
}

function cancelEditUser(){
  umEditIndex = -1;
  clearUmForm();
  document.getElementById('umFormTitle').textContent = '➕ เพิ่มผู้ใช้งานใหม่';
}

function clearUmForm(){
  ['umUsername','umName','umPassword'].forEach(id => document.getElementById(id).value='');
  document.getElementById('umRole').value = 'staff';
  document.getElementById('umUsername').disabled = false;
}

function saveUser(){
  const username = document.getElementById('umUsername').value.trim().toLowerCase();
  const name     = document.getElementById('umName').value.trim();
  const password = document.getElementById('umPassword').value;
  const role     = document.getElementById('umRole').value;

  if(!username || !name){ alert('กรุณากรอก Username และชื่อแสดง'); return; }
  if(!password && umEditIndex === -1){ alert('กรุณากรอกรหัสผ่าน'); return; }

  if(umEditIndex === -1){
    // Add new
    if(USERS.find(u => u.username === username)){ alert('Username นี้มีอยู่แล้ว'); return; }
    USERS.push({ username, password, role, name });
    addLog('USER_ADD', currentUser.name, `เพิ่ม user: ${username} (${role})`);
  } else {
    // Edit existing
    USERS[umEditIndex].name = name;
    USERS[umEditIndex].role = role;
    if(password) USERS[umEditIndex].password = password;
    addLog('USER_EDIT', currentUser.name, `แก้ไข user: ${username} -> role: ${role}`);
    umEditIndex = -1;
  }

  cancelEditUser();
  renderUmTable();
}

function deleteUser(i){
  const u = USERS[i];
  if(!confirm(`ลบ user "${u.username}" (${u.name})?`)) return;
  addLog('USER_DEL', currentUser.name, `ลบ user: ${u.username}`);
  USERS.splice(i, 1);
  renderUmTable();
}


