let poSyncing = false;

async function syncPOtoSheets(action, payload){
  try {
    poSyncing = true;
    showSyncStatus('🔄 กำลัง Sync...');
    const res = await fetch(PO_API, {
      method: 'POST',
      headers: {'Content-Type':'text/plain'},
      body: JSON.stringify({ secret: PO_SECRET, action, ...payload })
    });
    const data = await res.json();
    if(data.ok){
      showSyncStatus('✅ Sync สำเร็จ');
      setTimeout(()=>showSyncStatus(''), 3000);
    } else {
      showSyncStatus('⚠️ Sync ผิดพลาด');
      console.warn('Sync error:', data.error);
    }
    return data.ok;
  } catch(e){
    showSyncStatus('⚠️ ไม่สามารถเชื่อมต่อได้');
    console.warn('Sync error:', e);
    return false;
  } finally {
    poSyncing = false;
  }
}

async function loadPOFromSheets(){
  try {
    showSyncStatus('🔄 โหลด PO...');
    // โหลดจาก Google Sheets tab PO_Records โดยตรง (ไม่ผ่าน Apps Script)
    const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/PO_Records?key=${API_KEY}`;
    const res = await fetch(url);
    if(!res.ok) throw new Error('Sheets API error');
    const json = await res.json();
    const rows = json.values || [];
    if(rows.length < 2){ showSyncStatus(''); return getPORecords(); }

    // header: poNo,poDate,supplier,contact,creator,remark,subtotal,vatAmt,total,vatMode,status,cancelledAt,cancelledBy
    const headers = rows[0];
    const hi = (n) => headers.indexOf(n);

    // group by poNo
    const map = {};
    rows.slice(1).forEach(r => {
      const poNo = r[hi('poNo')]||r[0]||'';
      if(!poNo) return;
      if(!map[poNo]){
        map[poNo] = {
          poNo,
          poDate:    r[hi('poDate')]||r[1]||'',
          supplier:  r[hi('supplier')]||r[2]||'',
          contact:   r[hi('contact')]||r[3]||'',
          creator:   r[hi('creator')]||r[4]||'',
          remark:    r[hi('remark')]||r[5]||'',
          subtotal:  parseFloat(r[hi('subtotal')]||r[6])||0,
          vatAmt:    parseFloat(r[hi('vatAmt')]||r[7])||0,
          total:     parseFloat(r[hi('total')]||r[8])||0,
          vatMode:   parseInt((r[hi('vatMode')]||r[9]||'7').toString().replace('%',''))||7,
          status:    r[hi('status')]||r[10]||'active',
          cancelledAt: r[hi('cancelledAt')]||r[11]||'',
          cancelledBy: r[hi('cancelledBy')]||r[12]||'',
          items: []
        };
      }
    });

    // merge items จาก localStorage (เก็บข้อมูล item ละเอียดกว่า)
    const local = getPORecords();
    const records = Object.values(map);
    records.forEach(r => {
      const loc = local.find(l => l.poNo === r.poNo);
      if(loc){
        r.items = loc.items || [];
        r.hidePrices = loc.hidePrices || false;
        r.approverName = loc.approverName || '';
        r.approverSig  = loc.approverSig  || '';
        // ถ้า local มีสถานะที่ถูก cancel ให้ใช้จาก Sheets (source of truth)
      }
    });

    // เรียงจากใหม่ไปเก่า
    records.sort((a,b) => b.poNo.localeCompare(a.poNo));
    localStorage.setItem('vitoon_po_records', JSON.stringify(records.slice(0,200)));
    showSyncStatus('✅ โหลด PO สำเร็จ (' + records.length + ' ใบ)');
    setTimeout(()=>showSyncStatus(''), 3000);
    return records;
  } catch(e){
    console.warn('Load PO error:', e);
    showSyncStatus('⚠️ โหลด PO ไม่ได้ ใช้ข้อมูลในเครื่อง');
    setTimeout(()=>showSyncStatus(''), 4000);
    return getPORecords();
  }
}

