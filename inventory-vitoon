async function autoSavePDF(poNo, supplier){
  try {
    const { jsPDF } = window.jspdf;
    const printEl = document.getElementById('printArea');
    if(!printEl || !printEl.innerHTML) return;

    showSyncStatus('📄 กำลังสร้าง PDF...');

    // แสดง printArea ชั่วคราวเพื่อ render
    const prevDisplay = printEl.style.display;
    printEl.style.display = 'block';
    printEl.style.position = 'fixed';
    printEl.style.left = '-9999px';
    printEl.style.top = '0';
    printEl.style.width = '794px'; // A4 width px

    const canvas = await html2canvas(printEl, {
      scale: 2,
      useCORS: true,
      allowTaint: true,
      backgroundColor: '#ffffff',
      width: 794,
    });

    printEl.style.display = prevDisplay;
    printEl.style.position = '';
    printEl.style.left = '';
    printEl.style.top = '';
    printEl.style.width = '';

    const imgData = canvas.toDataURL('image/png');
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pdfW = pdf.internal.pageSize.getWidth();
    const pdfH = (canvas.height * pdfW) / canvas.width;

    // ถ้า content สูงกว่า 1 หน้า A4 → แบ่งหน้า
    const pageHeight = pdf.internal.pageSize.getHeight();
    if(pdfH <= pageHeight){
      pdf.addImage(imgData, 'PNG', 0, 0, pdfW, pdfH);
    } else {
      let yPos = 0;
      let remaining = pdfH;
      let page = 0;
      while(remaining > 0){
        if(page > 0) pdf.addPage();
        pdf.addImage(imgData, 'PNG', 0, -yPos, pdfW, pdfH);
        yPos += pageHeight;
        remaining -= pageHeight;
        page++;
      }
    }

    // ชื่อไฟล์: {PONo}_{Supplier}.pdf
    const safeName = (supplier||'').replace(/[\\/:*?"<>|]/g,'').trim() || 'PO';
    const filename = `${poNo}_${safeName}.pdf`;
    pdf.save(filename);

    showSyncStatus(`✅ บันทึก PDF: ${filename}`);
    setTimeout(()=>showSyncStatus(''), 4000);
    return filename;
  } catch(e){
    console.warn('autoSavePDF error:', e);
    showSyncStatus('⚠️ สร้าง PDF ไม่ได้: ' + e.message);
    setTimeout(()=>showSyncStatus(''), 4000);
    return '';
  }
}

function printPO(){
  const poNo   = document.getElementById('poNumber').value;
  const poDate = document.getElementById('poDate').value;
  const supplier = document.getElementById('poSupplier').value || '—';
  const contact  = document.getElementById('poContact').value || '';
  const creator  = document.getElementById('poCreator').value;
  const remark   = document.getElementById('poRemark').value;
  // แยก cart เป็น 2 กลุ่ม: สินค้าปกติ vs สินค้า NV (ที่อยู่ใน cart จริงๆ)
  const normalCart = cart.filter(c => !/NV$|\(NV\)|#NV/i.test(c.ProductCode||''));
  const nvCart     = cart.filter(c =>  /NV$|\(NV\)|#NV/i.test(c.ProductCode||''));

  // คำนวณยอดเฉพาะสินค้าปกติ (มีภาษี)
  const subtotal = priceMode === 'none' ? 0 : normalCart.reduce((s,c) => {
    const ep = c.customPrice !== undefined ? c.customPrice : c.LastPurchasePrice;
    return s + c.qty * ep;
  }, 0);
  const vatAmt = subtotal * vatMode / 100;
  const total  = subtotal + vatAmt;

  // คำนวณยอด NV (ไม่มีภาษี)
  const nvSubtotal = priceMode === 'none' ? 0 : nvCart.reduce((s,c) => {
    const ep = c.customPrice !== undefined ? c.customPrice : c.LastPurchasePrice;
    return s + c.qty * ep;
  }, 0);

  // แถวสินค้าปกติ
  const mainRows = normalCart.map((item,i) => {
    const ep = item.customPrice !== undefined ? item.customPrice : item.LastPurchasePrice;
    return `<tr>
      <td style="text-align:center">${i+1}</td>
      <td>${item.ProductCode}</td>
