function updatePOTotal(){
  if(priceMode === 'none'){
    document.getElementById('poTotal').textContent = 'รวมทั้งสิ้น: (ไม่แสดงราคา)';
    const s = document.getElementById('poSubtotal'); if(s) s.textContent='—';
    const v = document.getElementById('poVatAmt');   if(v) v.textContent='—';
    return;
  }
  const subtotal = cart.reduce((s,c) => {
    const ep = c.customPrice !== undefined ? c.customPrice : c.LastPurchasePrice;
    return s + c.qty * ep;
  }, 0);
  const vatAmt = subtotal * vatMode / 100;
  const grandTotal = subtotal + vatAmt;
  const sub = document.getElementById('poSubtotal'); if(sub) sub.textContent = fmtMoney(subtotal);
  const vat = document.getElementById('poVatAmt');   if(vat) vat.textContent = fmtMoney(vatAmt);
  const vatRow = document.getElementById('poVatRow');
  if(vatRow) vatRow.style.display = vatMode===0 ? 'none' : 'block';
  const lbl = vatMode===0 ? 'รวมทั้งสิ้น (ไม่มีVAT): ' : 'รวมทั้งสิ้น (รวมVAT): ';
  document.getElementById('poTotal').textContent = lbl + fmtMoney(grandTotal);
}

