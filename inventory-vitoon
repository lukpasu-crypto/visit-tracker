function cancelPOItem(poNo, productCode){
  if(!confirm('ยกเลิกสินค้า ' + productCode + ' ใน ' + poNo + '?')) return;
  const records = getPORecords();
  const rec = records.find(r => r.poNo === poNo);
  if(rec){
    const item = (rec.items||[]).find(it => it.ProductCode === productCode);
    if(item){ item.cancelledQty = item.qty; }
    // ถ้าทุกรายการถูกยกเลิกหมด → ยกเลิกทั้งใบ
    if(rec.items.every(it => (it.cancelledQty||0) >= it.qty)){
      rec.status = 'cancelled';
      rec.cancelledAt = new Date().toLocaleString('th-TH',{hour12:false});
    }
    localStorage.setItem('vitoon_po_records', JSON.stringify(records));
    addLog('PO_CANCEL_ITEM', currentUser?currentUser.name:'-', 'ยกเลิกรายการ ' + productCode + ' ใน ' + poNo);
    syncPOtoSheets('cancel_item', { poNo, productCode });
    renderPOHistory();
    alert('✅ ยกเลิกรายการ ' + productCode + ' แล้ว');
  }
}

