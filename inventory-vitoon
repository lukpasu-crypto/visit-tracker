  document.getElementById('poCreator').value = r.creator||'';
  document.getElementById('poRemark').value  = r.remark||'';

  // build print area
  const subtotal = r.subtotal || 0;
  const vatAmt   = r.vatAmt   || 0;
  const total    = r.total    || 0;
  // แยก normal vs NV (เหมือน printPO)
  const normalItems = cart.filter(c => !/NV$|\(NV\)|#NV/i.test(c.ProductCode||''));
  const nvItems     = cart.filter(c =>  /NV$|\(NV\)|#NV/i.test(c.ProductCode||''));

  const mainRows = normalItems.map((item,i) => {
    const ep = item.customPrice !== undefined ? item.customPrice : (item.UnitPrice || item.LastPurchasePrice || 0);
