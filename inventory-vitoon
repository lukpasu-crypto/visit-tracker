// รีเซ็ตสถานะ — ตรวจ QtyOnHand ปัจจุบัน vs ตอนกด PO
// ถ้าของเข้าแล้ว (qty เพิ่มขึ้น) → เปลี่ยนสถานะเป็น received เท่านั้น
// ไม่ลบ PO records
function resetPOStatusCache(){
  if(!confirm('รีเซ็ตสถานะ?\n\nระบบจะตรวจสต็อกปัจจุบัน\n- ถ้าของเข้าแล้ว → สถานะเปลี่ยนเป็น ✅ รับของแล้ว\n- PO ที่ยังรอของ → คงสถานะ 🔵 ไว้\n- ข้อมูล PO ไม่ถูกลบ')) return;

  const records = getPORecords();
  if(!records.length){ alert('ไม่มีข้อมูล PO'); return; }

  let updatedItems = 0;
  let updatedPO = 0;
  records.forEach(rec => {
    if(rec.status !== 'active') return;
    (rec.items||[]).forEach(item => {
      if((item.cancelledQty||0) >= item.qty) return;
      const prod = allData.find(d => d.ProductCode === item.ProductCode);
      if(!prod) return;
      const qtyNow = parseFloat(prod.QtyOnHand) || 0;
      const qtyAtOrder = item.qtyOnHandAtOrder !== undefined ? item.qtyOnHandAtOrder : 0;
      if(qtyNow > qtyAtOrder){
        item.received = true;
        updatedItems++;
      }
    });
    // นับ PO ที่ของเข้าครบ (ไม่เปลี่ยน status ให้ข้อมูลคงอยู่)
    const activeItems = (rec.items||[]).filter(it => (it.cancelledQty||0) < it.qty);
    if(activeItems.length > 0 && activeItems.every(it => it.received)){
      updatedPO++;
    }
  });

  localStorage.setItem('vitoon_po_records', JSON.stringify(records));
  renderTable();

  alert('✅ รีเซ็ตสถานะเรียบร้อย\nของเข้า ' + updatedItems + ' รายการ | PO ที่ของเข้าครบ ' + updatedPO + ' ใบ\n\nดูสถานะ ✅ ของเข้าแล้ว ได้ที่ปุ่ม ประวัติ PO ค่ะ');
}
