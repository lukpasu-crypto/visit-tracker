      <td style="text-align:right">${priceMode==='none' ? '—' : fmtMoney(ep)}</td>
      <td style="text-align:right">${priceMode==='none' ? '—' : fmtMoney(item.qty * ep)}</td>
    </tr>`;
  }).join('');

  // แถวสินค้า NV (แยก section ไม่คิดภาษี)
  let nvRows = '';
  if(nvCart.length > 0){
    const nvHeader = `<tr style="background:#FFF0F0;border-top:2px solid #DC2626;">
      <td colspan="7" style="padding:5px 10px;font-size:11px;font-weight:700;color:#DC2626;">
        รายการสินค้า NV (ไม่มีภาษี)
      </td>
    </tr>`;
    const nvItemRows = nvCart.map((item,i) => {
      const ep = item.customPrice !== undefined ? item.customPrice : item.LastPurchasePrice;
      return `<tr style="background:#FFF8F8;">
        <td style="text-align:center;color:#DC2626">${normalCart.length + i + 1}</td>
        <td style="color:#DC2626;font-weight:700">${item.ProductCode}</td>
        <td>${item.ProductName}</td>
        <td style="text-align:center">${fmtNum(item.qty)}</td>
        <td style="text-align:center;font-size:12px">${item.UnitName||'—'}</td>
        <td style="text-align:right">${priceMode==='none' ? '—' : fmtMoney(ep)}</td>
        <td style="text-align:right">${priceMode==='none' ? '—' : fmtMoney(item.qty * ep)}</td>
      </tr>`;
    }).join('');
    nvRows = nvHeader + nvItemRows;
  }

  // companion NV ประกอบ → ไม่แสดงในพิมพ์เลย
  const rows = mainRows + nvRows;

  const _apvSel = document.getElementById('poApprover');
  const _apvOpt = _apvSel ? _apvSel.options[_apvSel.selectedIndex] : null;
  const _apvName = _apvOpt ? (_apvOpt.dataset.name || _apvOpt.textContent.replace(' ✍️','')) : '';
  const _apvSig  = _apvOpt ? (_apvOpt.dataset.sig || '') : '';
  document.getElementById('printArea').innerHTML = buildPrintHTML(poNo, poDate, supplier, contact, creator, remark, rows, subtotal, vatAmt, total, vatMode, nvSubtotal, nvCart.length > 0, _apvName, _apvSig);

  // บันทึก supplier เสมอ (ไม่ว่าจะยืนยันหรือไม่)
  saveSupplier(supplier, contact);
  setTimeout(()=>{
    window.print();
    setTimeout(()=>{
      if(confirm('พิมพ์เสร็จแล้วใช่ไหมครับ?\nกด OK เพื่อบันทึกลง Google Sheets และล้างรายการ')){
        // บันทึก PO ลง localStorage เฉพาะเมื่อยืนยัน
        savePORecord(poNo, poDate, supplier, contact, creator, remark, subtotal, vatAmt, total);
        savePOtoSheets(poNo, poDate, supplier, contact, creator, remark, subtotal, vatAmt, total);
        // Auto-save PDF
        autoSavePDF(poNo, supplier);
      }
    }, 1000);
  }, 200);
}

async function savePOtoSheets(poNo, poDate, supplier, contact, creator, remark, subtotal, vatAmt, total){
  // ถ้าเรียกจากปุ่มโดยตรง (ไม่ผ่าน printPO)
  if(!poNo){
    poNo     = document.getElementById('poNumber').value;
    poDate   = document.getElementById('poDate').value;
    supplier = document.getElementById('poSupplier').value || '';
    contact  = document.getElementById('poContact').value || '';
    creator  = document.getElementById('poCreator').value;
    remark   = document.getElementById('poRemark').value;
    subtotal = cart.reduce((s,c)=>{ const ep=c.customPrice!==undefined?c.customPrice:c.LastPurchasePrice; return s+c.qty*ep; },0);
    vatAmt   = subtotal * vatMode / 100;
    total    = subtotal + vatAmt;
  }

  const now = new Date().toLocaleString('th-TH',{hour12:false});
  const rows = cart.map(item => {
    const ep = item.customPrice !== undefined ? item.customPrice : item.LastPurchasePrice;
    return [poNo, poDate, supplier, contact, creator,
      item.ProductCode, item.ProductName,
      item.qty, ep, item.qty * ep,
      vatMode+'%', remark, now];
  });

  // บันทึกลง Google Sheets ผ่าน API (append)
  let sheetsOk = false;
  try {
    const token = gDriveToken; // จาก OAuth
    if(token){
      const appendUrl = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/PO_Orders!A1:M1:append?valueInputOption=USER_ENTERED&insertDataOption=INSERT_ROWS`;
      const res = await fetch(appendUrl, {
        method:'POST',
        headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
        body: JSON.stringify({ values: rows })
      });
      if(res.ok){ sheetsOk = true; addLog('PO_SHEETS', currentUser?currentUser.name:'-', poNo+' บันทึกลง Sheets สำเร็จ'); }
    }
  } catch(e){ console.warn('Sheets append error:', e); }

  // Upload PDF ไป Google Drive
  let driveUrl = '';
  try {
    if(gDriveToken){
      driveUrl = await uploadPDFtoDrive(poNo);
      if(driveUrl) updatePODriveUrl(poNo, driveUrl);
    }
  } catch(e){ console.warn('Drive upload error:', e); }

  // ล้างรายการหลังบันทึก
  cart = [];
  updateCartBadge();
  updateCartButtons(); // คืนปุ่ม "+ สั่งซื้อ" ทุกแถว
  renderTable();       // refresh สถานะ 🔵 ในตาราง
  closePO();

  // แจ้งผล
  let msg = '✅ บันทึก PO สำเร็จ: ' + poNo;
  if(sheetsOk) msg += '\n📊 บันทึกลง Google Sheets แล้ว';
  if(driveUrl) msg += '\n📁 PDF อัปโหลด Drive แล้ว';
  alert(msg);
}

