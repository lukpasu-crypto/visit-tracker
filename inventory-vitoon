        <span class="ac-item-del" onmousedown="deleteSupplier('${s.name.replace(/'/g,"\'")}',event)">✕</span>
      </div>`).join('');
  }
  acActiveIdx = -1;
  list.classList.add('show');
}

function acHide(listId){
  const el = document.getElementById(listId);
  if(el) el.classList.remove('show');
  acActiveIdx = -1;
}

function acSelect(inputId, listId, val){
  document.getElementById(inputId).value = val;
  acHide(listId);
}

function acSelectSupplier(name){
  document.getElementById('poSupplier').value = name;
  acHide('acSupplier');
  // auto fill contact ถ้ามีแค่ 1
  const s = getSuppliers().find(s => s.name === name);
  if(s && s.contacts.length === 1){
    document.getElementById('poContact').value = s.contacts[0];
  } else if(s && s.contacts.length > 1){
    setTimeout(()=>acShow('poContact','acContact'), 100);
  }
}

function acKey(e, inputId, listId){
  const list = document.getElementById(listId);
  const items = list.querySelectorAll('.ac-item');
  if(!items.length) return;
  if(e.key==='ArrowDown'){ acActiveIdx=Math.min(acActiveIdx+1,items.length-1); acHighlight(items); e.preventDefault(); }
  else if(e.key==='ArrowUp'){ acActiveIdx=Math.max(acActiveIdx-1,0); acHighlight(items); e.preventDefault(); }
  else if(e.key==='Enter' && acActiveIdx>=0){ items[acActiveIdx].dispatchEvent(new MouseEvent('mousedown')); e.preventDefault(); }
  else if(e.key==='Escape'){ acHide(listId); }
}

function acHighlight(items){
  items.forEach((el,i)=>el.classList.toggle('active', i===acActiveIdx));
  if(acActiveIdx>=0) items[acActiveIdx].scrollIntoView({block:'nearest'});
}

