function startScheduler(){
  setInterval(()=>{
    if(!DB.settings.autoSend) return;
    const n   = new Date();
    const hh  = n.getHours();
    const mm  = n.getMinutes();
    const day = n.toISOString().slice(0,10);

    // ส่งได้เฉพาะ 19:00 น. เท่านั้น
    if(hh !== 19 || mm !== 0) return;

    // กัน race condition ระหว่างหลายแท็บ — ใช้ localStorage เป็น lock
    const lockKey = 'line_sent_' + day;
    const alreadySent = localStorage.getItem(lockKey);
    if(alreadySent) return;

    const p = DB.records.filter(r=>!r.sent);
    if(!p.length) return;

    // set lock ทันที ก่อนส่ง
    localStorage.setItem(lockKey, new Date().toISOString());
    sendLineNow(p);
  }, 60000); // เช็คทุก 1 นาที
}

