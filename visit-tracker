function dbSave(){
  try{
    // ไม่เก็บ photos base64 ใน localStorage (ใช้พื้นที่มาก)
    // เก็บเฉพาะ photoUrls (Drive link) ที่อัปโหลดแล้ว
    const dbClean={...DB, records: DB.records.map(r=>({...r, photos:[]}))};
    localStorage.setItem('cvs3', JSON.stringify(dbClean));
  } catch(e){
    // ถ้า quota เต็ม — ลอง clear รูปเก่าแล้ว save ใหม่
    try{
      DB.records.forEach(r=>{ r.photos=[]; });
      localStorage.setItem('cvs3', JSON.stringify(DB));
      toast('⚠️ ล้างรูปชั่วคราวออกจากหน่วยความจำ (Drive link ยังอยู่)','info');
    } catch(e2){
      toast('⚠️ หน่วยความจำเต็ม กรุณา Export JSON สำรองข้อมูลก่อน','err');
    }
  }
}
function dbLoad(){
  try{const s=localStorage.getItem('cvs3');if(s){const p=JSON.parse(s);DB={...DB,...p};DB.settings={...DB.settings,...(p.settings||{})};}}catch(e){}
}

