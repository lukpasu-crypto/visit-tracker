// ══════════════════════════════════════════════
// COLLAGE MAKER (Browser Canvas) — แบบ v4
// รวมรูปหลายใบเป็นรูปเดียวก่อนส่ง GAS
// ══════════════════════════════════════════════
async function makeCollage(dataUrls){
  if(!dataUrls || dataUrls.length === 0) return null;
  if(dataUrls.length === 1) return dataUrls[0];  // รูปเดียว คืนเลย

  return new Promise(resolve=>{
    const n    = Math.min(dataUrls.length, 6);
    const cols = n <= 2 ? n : n <= 4 ? 2 : 3;
    const rows = Math.ceil(n / cols);
    const W    = 1200, H = 900;
    const cellW = Math.floor(W / cols);
    const cellH = Math.floor(H / rows);
    const pad   = 4;

    const canvas = document.createElement('canvas');
    canvas.width  = W;
    canvas.height = H;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, W, H);

    let loaded = 0;
    for(let i = 0; i < n; i++){
      const img = new Image();
      img.onload = ()=>{
        const col = i % cols;
        const row = Math.floor(i / cols);
        const x   = col * cellW + pad;
        const y   = row * cellH + pad;
        const w   = cellW - pad * 2;
        const h   = cellH - pad * 2;

        // crop ให้พอดีกับ cell (object-fit: cover)
        const scale = Math.max(w / img.width, h / img.height);
        const sw    = w / scale, sh = h / scale;
        const sx    = (img.width  - sw) / 2;
        const sy    = (img.height - sh) / 2;
        ctx.drawImage(img, sx, sy, sw, sh, x, y, w, h);

        loaded++;
        if(loaded === n){
          resolve(canvas.toDataURL('image/jpeg', 0.82));
        }
      };
      img.onerror = ()=>{ loaded++; if(loaded === n) resolve(canvas.toDataURL('image/jpeg', 0.82)); };
      img.src = dataUrls[i];
    }
  });
}

// ══════════════════════════════════════════════
// PHOTO COMPRESSION — บีบรูปก่อนส่ง GAS
// ══════════════════════════════════════════════
function compressPhoto(dataUrl, maxW, quality){
  return new Promise(resolve=>{
    const img = new Image();
    img.onload = ()=>{
      const mw = maxW || 1280;
      const q  = quality || 0.75;
      let w = img.width, h = img.height;
      if(w > mw){ h = Math.round(h * mw/w); w = mw; }
      const canvas = document.createElement('canvas');
      canvas.width=w; canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      resolve(canvas.toDataURL('image/jpeg', q));
    };
    img.onerror = ()=>resolve(dataUrl); // fallback ถ้า compress ล้มเหลว
    img.src = dataUrl;
  });
}

async function compressPhotos(photos){
  const results = [];
  for(const p of photos){
    try{
      const compressed = await compressPhoto(p, 1280, 0.75);
      const origKB  = (p.length/1024).toFixed(0);
      const compKB  = (compressed.length/1024).toFixed(0);
      console.log(`Photo compressed: ${origKB}KB → ${compKB}KB`);
      results.push(compressed);
    }catch(e){ results.push(p); }
  }
  return results;
}

