// AUTO SYNC — ดึงข้อมูลจาก Sheets เมื่อเปิด Dashboard
// ══════════════════════════════════════════════
var _lastSyncTime = 0;
var _syncCooldownMs = 60 * 1000; // cooldown 1 นาที (กัน sync ซ้ำถี่เกิน)

async function autoSyncDashboard(){
  const url = DB.settings.gasUrl;
  if(!url) return;

  const now = Date.now();
  if(now - _lastSyncTime < _syncCooldownMs) return; // cooldown 1 นาที
  _lastSyncTime = now;

  const btn = document.getElementById('btn-sync-sheets');
  const syncStatus = document.getElementById('sync-status');
  if(btn){ btn.textContent='⏳ Syncing...'; btn.disabled=true; }
  if(syncStatus){ syncStatus.textContent='⟳ กำลัง Sync...'; syncStatus.style.display='inline'; }

  try{
    // ใช้ GET request เพื่อหลีกเลี่ยงปัญหา CORS และ action ไม่ผ่าน POST
    const getUrl = url + (url.includes('?')?'&':'?') + 'action=getRecordsFromSheet';
    const res = await gasGetWithRead(getUrl, 30000);
    if(res.ok && res.data && res.data.success && res.data.records){
      const sheetRecs = res.data.records;
      // Sheet คือ source of truth — ใช้ข้อมูลจาก Sheet เป็นหลัก
      // ถ้า Sheet ว่าง = ล้าง local ด้วย (ไม่เอา local ที่อาจเป็นข้อมูลเก่า)
      const before    = DB.records.length;
      DB.records = sheetRecs; // ใช้ Sheet อย่างเดียว
      dbSave();
      buildCustomerList();
      renderDashboard();
      renderHistory();
      const diff = DB.records.length - before;
      if(syncStatus){
        syncStatus.textContent = `✅ Synced (${DB.records.length} รายการ${diff>0?' +'+diff:''})`;
        setTimeout(()=>{ if(syncStatus) syncStatus.style.display='none'; }, 3000);
      }
    } else {
      if(syncStatus){ syncStatus.textContent='⚠️ Sync ไม่สำเร็จ'; setTimeout(()=>{ syncStatus.style.display='none'; },3000); }
    }
  }catch(e){
    if(syncStatus){ syncStatus.textContent='⚠️ Sync error'; setTimeout(()=>{ syncStatus.style.display='none'; },3000); }
  }
  finally{
    if(btn){ btn.textContent='☁️ Sync จาก Sheets'; btn.disabled=false; }
  }
}

