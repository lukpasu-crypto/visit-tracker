function onDFilt(){
  const f=document.getElementById('d-filter').value;
  const isYear=f==='year';
  const isQ=f.startsWith('q');
  document.getElementById('d-year').style.display=(isYear||isQ)?'':'none';
  document.getElementById('d-month').style.display=isYear?'':'none';
  document.getElementById('d-from').style.display=f==='custom'?'':'none';
  document.getElementById('d-to').style.display=f==='custom'?'':'none';
  renderDashboard();
}

function getDashData(){
  const f=document.getElementById('d-filter').value;
  const yr=parseInt(document.getElementById('d-year').value);
  const mo=parseInt(document.getElementById('d-month').value);
  const now=new Date();
  const qRange={q1:[1,3],q2:[4,6],q3:[7,9],q4:[10,12]};
  return DB.records.filter(r=>{
    // แปลง date ให้เป็น ISO ค.ศ. ก่อนเปรียบเทียบ
    var rawD = r.date||'';
    var pts  = rawD.split('-');
    var isoD = rawD;
    if(pts.length===3 && parseInt(pts[0])>2500){
      isoD = (parseInt(pts[0])-543)+'-'+pts[1]+'-'+pts[2];
    }
    const d=new Date(isoD+'T00:00:00');
    if(isNaN(d)) return false;

    if(f==='year'){if(d.getFullYear()!==yr)return false;if(mo>0&&(d.getMonth()+1)!==mo)return false;}
    else if(f==='month')return d.getFullYear()===now.getFullYear()&&d.getMonth()===now.getMonth();
    else if(f==='week'){
      // สัปดาห์นี้ = จันทร์-อาทิตย์ ไม่ใช่ย้อนหลัง 7 วัน
      const dow=now.getDay();
      const mon=new Date(now); mon.setDate(now.getDate()-((dow+6)%7)); mon.setHours(0,0,0,0);
      const sun=new Date(mon); sun.setDate(mon.getDate()+6); sun.setHours(23,59,59,999);
      return d>=mon && d<=sun;
    }
    else if(f==='day'){
      const today=now.toISOString().slice(0,10);
      return isoD===today;
    }
    else if(f==='custom'){
      const fr=document.getElementById('d-from').value,to=document.getElementById('d-to').value;
      if(fr&&isoD<fr)return false; if(to&&isoD>to)return false;
    } else if(qRange[f]){
      const [qs,qe]=qRange[f]; const m=d.getMonth()+1;
      if(d.getFullYear()!==yr)return false;
      if(m<qs||m>qe)return false;
    }
    return true;
  });
}

function renderDashboard(){
  const data = getDashData();

  // ── populate emp filter dropdown ──
  const empSel = document.getElementById('d-emp-filter');
  if(empSel){
    const cur = empSel.value;
    empSel.innerHTML = '<option value="">ทุกคน</option>' +
      DB.employees.map(e=>`<option value="${e}" ${e===cur?'selected':''}>${e}</option>`).join('');
  }

  // ── KPI numbers ──
  const total    = data.length;
  const amt      = data.reduce((s,r)=>s+(r.amount||0),0);
  const empSet   = new Set(data.map(r=>r.employee).filter(Boolean));
  const closed   = data.filter(r=>(r.results||[]).includes('closed')||(r.result&&r.result.includes('ปิดการขาย'))).length;

  // ── KPI ลูกค้าใหม่/เก่า ──
  // กฎ:
  //   ลูกค้าใหม่          = ชื่อไม่ซ้ำใน period (unique) — ไม่เคยเยี่ยม หรือ < 1 ปี
  //   ติดตามผลต่อเนื่อง  = ชื่อซ้ำใน period (เยี่ยมมากกว่า 1 ครั้ง)
  //   ลูกค้าเก่า         = เคยเยี่ยมครั้งแรก > 1 ปีแล้ว
  const ONE_YEAR_MS = 365 * 24 * 60 * 60 * 1000;
  const now_ms = Date.now();

  // หาวันที่เยี่ยมครั้งแรกสุดของทุกลูกค้า (DB ทั้งหมด)
  const firstVisitMap = {};
  DB.records.forEach(r=>{
    const k = (r.customer||'').trim().toLowerCase();
    if(!k || !r.date) return;
    if(!firstVisitMap[k] || r.date < firstVisitMap[k]) firstVisitMap[k] = r.date;
  });

  // นับชื่อซ้ำใน period
  const custCountInPeriod = {};
  data.forEach(r=>{
    const k = (r.customer||'').trim().toLowerCase();
    if(!k) return;
    custCountInPeriod[k] = (custCountInPeriod[k]||0) + 1;
  });

  let trueNewCust = 0, trueFollowup = 0, trueOldCust = 0;
  Object.entries(custCountInPeriod).forEach(([k, cnt])=>{
    const firstDate = firstVisitMap[k];
    const ageMs = firstDate ? now_ms - new Date(firstDate).getTime() : 0;
    const isOld = ageMs >= ONE_YEAR_MS;

    if(isOld){
      trueOldCust++;   // เยี่ยมครั้งแรก > 1 ปี = ลูกค้าเก่า
    } else if(cnt > 1){
      trueFollowup++;  // ชื่อซ้ำใน period = ติดตามผลต่อเนื่อง
    } else {
      trueNewCust++;   // ชื่อไม่ซ้ำ + < 1 ปี = ลูกค้าใหม่
    }
  });

  const uniqueCust = Object.keys(custCountInPeriod).length;

  // KPI Cards
  const cards = [
    {icon:'📋', label:'การเยี่ยม',        val:total,      unit:'ครั้ง', kc:'#7c3aed'},
    {icon:'💰', label:'ยอดรวม',          val:amt>=1000000?`${(amt/1000000).toFixed(1)}M`:amt>=1000?`${(amt/1000).toFixed(1)}K`:amt.toLocaleString(), unit:'บาท', kc:'#059669'},
    {icon:'👥', label:'พนักงาน',         val:empSet.size, unit:'คน',   kc:'#2563eb'},
    {icon:'🎯', label:'ปิดการขาย',      val:closed,      unit:'ราย',  kc:'#d97706'},
    {icon:'✨', label:'ลูกค้าใหม่',          val:trueNewCust,  unit:'ราย', kc:'#10b981', note:'(unique, <1ปี)'},
    {icon:'📋', label:'ติดตามผลต่อเนื่อง', val:trueFollowup, unit:'ราย', kc:'#f59e0b', note:'(ชื่อซ้ำ <1ปี)'},
    {icon:'🔁', label:'ลูกค้าเก่า',         val:trueOldCust,  unit:'ราย', kc:'#ef4444', note:'(>1ปี)'},
  ];
  document.getElementById('d-kpi-cards').innerHTML = cards.map(k=>`
    <div class="kpi-card">
      <div class="kpi-card-top">
        <div class="kpi-icon-wrap" style="background:${k.kc}22">${k.icon}</div>
      </div>
      <div class="kpi-label">${k.label}</div>
      <div class="kpi-val">${k.val}</div>
      <div class="kpi-unit">${k.unit}</div>
      ${k.note?`<div style="font-size:10px;color:#94a3b8;margin-top:2px">${k.note}</div>`:''}
      <div class="kpi-stripe" style="background:${k.kc}"></div>
    </div>`).join('');

  // ── Monthly LINE chart — เทียบแต่ละ Sale ──
  const LINE_COLORS = ['#4f75ff','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#84cc16'];
  const empNames2 = [...new Set(data.map(r=>r.employee).filter(Boolean))].sort();

  // นับแต่ละ Sale แต่ละเดือน
  const empMonData = {};
  empNames2.forEach(e=>{ empMonData[e]=Array(12).fill(0); });
  data.forEach(r=>{
    const e=r.employee; if(!e||!r.date) return;
    empMonData[e][new Date(r.date).getMonth()]++;
  });

  const allVals = empNames2.flatMap(e=>empMonData[e]);
  const maxVal  = Math.max(...allVals, 1);

  // SVG dimensions — ปรับตาม container จริง
  const svgEl2 = document.getElementById('ch-mon');
  const W = Math.max((svgEl2 ? svgEl2.parentElement.clientWidth : 340) - 8, 300);
  const H=150, padL=28, padR=10, padT=12, padB=24;
  const chartW = W-padL-padR, chartH = H-padT-padB;
  const stepX  = chartW/11; // 12 เดือน = 11 intervals

  // Y grid lines
  const ySteps = 4;
  let svgHtml = '';
  for(let i=0;i<=ySteps;i++){
    const y=padT+chartH*(1-i/ySteps);
    const val=Math.round(maxVal*i/ySteps);
    svgHtml+=`<line x1="${padL}" y1="${y}" x2="${W-padR}" y2="${y}" stroke="#e2e6ef" stroke-width="0.5"/>`;
    if(i>0) svgHtml+=`<text x="${padL-3}" y="${y+3}" text-anchor="end" font-size="8" fill="#94a3b8">${val}</text>`;
  }

  // X axis labels (month)
  MONTHS.forEach((m,i)=>{
    const x=padL+i*stepX;
    svgHtml+=`<text x="${x}" y="${H-4}" text-anchor="middle" font-size="8.5" fill="#94a3b8">${m}</text>`;
  });

  // Lines per Sale
  empNames2.forEach((e,ei)=>{
    const color=LINE_COLORS[ei%LINE_COLORS.length];
    const pts=empMonData[e].map((v,i)=>{
      const x=padL+i*stepX;
      const y=padT+chartH*(1-v/maxVal);
      return [x,y];
    });
    // polyline
    const pointStr=pts.map(p=>p[0]+','+p[1]).join(' ');
    svgHtml+=`<polyline points="${pointStr}" fill="none" stroke="${color}" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/>`;
    // dots + value
    pts.forEach(([x,y],i)=>{
      const v=empMonData[e][i];
      if(v>0){
        svgHtml+=`<circle cx="${x}" cy="${y}" r="3" fill="${color}"/>`;
        svgHtml+=`<text x="${x}" y="${y-5}" text-anchor="middle" font-size="8" fill="${color}" font-weight="600">${v}</text>`;
      } else {
        svgHtml+=`<circle cx="${x}" cy="${y}" r="2" fill="${color}" opacity="0.25"/>`;
      }
    });
  });

  const svgEl = document.getElementById('ch-mon');
  svgEl.setAttribute('viewBox',`0 0 ${W} ${H}`);
  svgEl.setAttribute('width','100%');
  svgEl.innerHTML = svgHtml;

  // Legend
  const legEl = document.getElementById('ch-mon-legend');
  if(legEl) legEl.innerHTML = empNames2.map((e,i)=>`
    <div style="display:flex;align-items:center;gap:4px">
      <div style="width:14px;height:3px;background:${LINE_COLORS[i%LINE_COLORS.length]};border-radius:2px"></div>
      <span style="color:var(--text2)">${e}</span>
    </div>`).join('');

  // ── Employee KPI Ranking ──
  const empStats = {};
  data.forEach(r=>{
    const e = r.employee||'ไม่ระบุ';
    if(!empStats[e]) empStats[e]={visits:0,amount:0,closed:0,newCust:0};
    empStats[e].visits++;
    empStats[e].amount += (r.amount||0);
    if(r.result&&r.result.includes('ปิดการขาย')) empStats[e].closed++;
    if((r.purposes||[]).includes('new')) empStats[e].newCust++;
  });
  const empRank = Object.entries(empStats).sort((a,b)=>b[1].visits-a[1].visits);
  const maxV    = Math.max(...empRank.map(x=>x[1].visits),1);
  const maxAmt  = Math.max(...empRank.map(x=>x[1].amount),1);
  const medals  = ['gold','silver','bronze'];

  const noData = `<div class="no-data"><div style="font-size:32px">📊</div>ยังไม่มีข้อมูล</div>`;
  document.getElementById('ch-emp-rank').innerHTML = empRank.length===0 ? noData :
    empRank.map(([name,s],i)=>`
      <div class="emp-rank-row">
        <div class="emp-rank-no ${medals[i]||''}">${i===0?'🥇':i===1?'🥈':i===2?'🥉':i+1}</div>
        <div class="emp-rank-name">${name}</div>
        <div class="emp-rank-bars">
          <div class="emp-bar-row">
            <div style="font-size:9.5px;color:var(--text3);width:36px">เยี่ยม</div>
            <div class="emp-bar-bg"><div class="emp-bar-fill" style="width:${s.visits/maxV*100}%;background:var(--accent)"></div></div>
            <div class="emp-bar-lbl">${s.visits}</div>
          </div>
          <div class="emp-bar-row">
            <div style="font-size:9.5px;color:var(--text3);width:36px">ยอด</div>
            <div class="emp-bar-bg"><div class="emp-bar-fill" style="width:${s.amount/maxAmt*100}%;background:var(--green)"></div></div>
            <div class="emp-bar-lbl" style="font-size:9px">${s.amount>=1000?(s.amount/1000).toFixed(0)+'K':s.amount}</div>
          </div>
        </div>
        <div class="emp-rank-stats">
          <div class="emp-stat-num" style="color:var(--accent)">${s.visits}</div>
          <div class="emp-stat-sub">ครั้ง</div>
          <div class="emp-stat-num" style="color:var(--orange);font-size:11px">${s.closed} ปิด</div>
        </div>
      </div>`).join('');

  // ── Donut: Customer types ──
  const tc={tech:0,retail:0,wholesale:0,proj:0,gov:0};
  data.forEach(r=>r.types.forEach(t=>{if(tc[t]!==undefined)tc[t]++;}));
  const ttl=Object.values(tc).reduce((a,b)=>a+b,0)||1;
  let cum=0;
  const paths=Object.entries(tc).map(([t,cnt])=>{
    if(!cnt)return'';
    const a=cnt/ttl*360,rv=35,cx=50,cy=50;
    const a1=(cum-90)*Math.PI/180,a2=(cum+a-90)*Math.PI/180;
    const x1=cx+rv*Math.cos(a1),y1=cy+rv*Math.sin(a1),x2=cx+rv*Math.cos(a2),y2=cy+rv*Math.sin(a2);
    cum+=a;
    return`<path d="M${cx},${cy}L${x1},${y1}A${rv},${rv} 0 ${a>180?1:0},1 ${x2},${y2}Z" fill="${TYPE_COLORS[t]}" opacity=".85"/>`;
  }).join('');
  document.getElementById('ch-donut').innerHTML=paths+`<circle cx="50" cy="50" r="20" fill="var(--card)"/>`;
  document.getElementById('ch-dleg').innerHTML=Object.entries(tc).filter(([,v])=>v>0).map(([t,cnt])=>`
    <div class="dleg-item"><div class="dleg-dot" style="background:${TYPE_COLORS[t]}"></div>
    <span>${TYPE_LABEL[t]}: <strong>${cnt}</strong></span></div>`).join('');

  // ── Province horizontal bar ──
  const pc={};
  data.forEach(r=>{if(r.province)pc[r.province]=(pc[r.province]||0)+1;});
  const topP=Object.entries(pc).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const mxP=Math.max(...topP.map(p=>p[1]),1);
  const provColors=['#4f75ff','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#84cc16','#f97316','#14b8a6'];
  document.getElementById('ch-prov').innerHTML=topP.length===0?noData
    :topP.map(([p,cnt],i)=>`
    <div style="display:flex;align-items:center;gap:8px;font-size:12px">
      <div style="width:80px;text-align:right;color:var(--text2);font-size:11px;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${p}">${p}</div>
      <div style="flex:1;background:var(--bg3);border-radius:4px;height:18px;overflow:hidden">
        <div style="width:${cnt/mxP*100}%;background:${provColors[i%provColors.length]};height:100%;border-radius:4px;transition:width .4s;display:flex;align-items:center;justify-content:flex-end;padding-right:5px">
          <span style="font-size:10px;font-weight:700;color:#fff">${cnt}</span>
        </div>
      </div>
      <div style="width:20px;font-size:10px;color:var(--text3);flex-shrink:0">${cnt}</div>
    </div>`).join('');

  // ── Sale KPI Cards (แยกตาม Sale) ──
  const ONE_YEAR_MS2 = 365*24*60*60*1000;
  const now_ms2 = Date.now();

  // หา first visit ของทุกลูกค้า (จาก DB ทั้งหมด)
  const fvMap = {};
  DB.records.forEach(r=>{
    const k=(r.customer||'').trim().toLowerCase();
    if(!k||!r.date) return;
    if(!fvMap[k]||r.date<fvMap[k]) fvMap[k]=r.date;
  });

  // จัดกลุ่มตาม Sale
  const saleMap={};
  data.forEach(r=>{
    const e=r.employee||'ไม่ระบุ';
    if(!saleMap[e]) saleMap[e]=[];
    saleMap[e].push(r);
  });

  const saleHtml = Object.entries(saleMap)
    .sort((a,b)=>b[1].reduce((s,r)=>s+(r.amount||0),0)-a[1].reduce((s,r)=>s+(r.amount||0),0))
    .map(([name, recs])=>{
      const amt = recs.reduce((s,r)=>s+(r.amount||0),0);
      const closed = recs.filter(r=>(r.results||[]).includes('closed')||(r.resultNote||'').includes('ปิดการขาย')).length;

      // นับลูกค้าแต่ละประเภท (unique customer)
      const custCount={};
      recs.forEach(r=>{
        const k=(r.customer||'').trim().toLowerCase();
        if(!k) return;
        custCount[k]=(custCount[k]||0)+1;
      });

      let newUnique=0, followCnt=0, oldCust=0;
      Object.entries(custCount).forEach(([k,cnt])=>{
        const fd=fvMap[k];
        const age=fd?now_ms2-new Date(fd).getTime():0;
        if(age>=ONE_YEAR_MS2){ oldCust++; }
        else if(cnt>1){ followCnt++; } // ชื่อซ้ำใน period = ติดตามผล (ครั้งที่ 2+)
        else { newUnique++; }           // ชื่อไม่ซ้ำ = ลูกค้าใหม่
      });

      // นับจำนวน visit ที่เป็น followup (ครั้งที่ 2 เป็นต้นไป ภายใน period)
      const followVisits = Object.entries(custCount)
        .filter(([k,cnt])=>{
          const fd=fvMap[k];
          const age=fd?now_ms2-new Date(fd).getTime():0;
          return age<ONE_YEAR_MS2 && cnt>1;
        })
        .reduce((s,[k,cnt])=>s+(cnt-1),0); // นับเฉพาะครั้งที่ 2+

      const totalVisits = recs.length;

      return `
      <div style="background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:14px 16px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <div style="font-size:14px;font-weight:700;color:var(--text)">👤 ${name}</div>
          <div style="font-size:12px;color:var(--text3)">${totalVisits} ครั้ง รวม</div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px">
          <div style="background:var(--bg2);border-radius:8px;padding:10px 12px;border-left:3px solid #10b981">
            <div style="font-size:10px;color:var(--text3);margin-bottom:4px">✨ ลูกค้าใหม่ (ไม่ซ้ำ)</div>
            <div style="font-size:22px;font-weight:800;color:#10b981;line-height:1">${newUnique}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">ราย</div>
          </div>
          <div style="background:var(--bg2);border-radius:8px;padding:10px 12px;border-left:3px solid #f59e0b">
            <div style="font-size:10px;color:var(--text3);margin-bottom:4px">📋 ลูกค้าใหม่ ติดตามผล</div>
            <div style="font-size:22px;font-weight:800;color:#f59e0b;line-height:1">${followCnt}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">ราย · ${followVisits} ครั้ง</div>
          </div>
          <div style="background:var(--bg2);border-radius:8px;padding:10px 12px;border-left:3px solid #ef4444">
            <div style="font-size:10px;color:var(--text3);margin-bottom:4px">🔁 ลูกค้าเก่า (&gt;1ปี)</div>
            <div style="font-size:22px;font-weight:800;color:#ef4444;line-height:1">${oldCust}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">ราย</div>
          </div>
          <div style="background:var(--bg2);border-radius:8px;padding:10px 12px;border-left:3px solid #7c3aed">
            <div style="font-size:10px;color:var(--text3);margin-bottom:4px">🎯 ปิดการขาย</div>
            <div style="font-size:22px;font-weight:800;color:#7c3aed;line-height:1">${closed}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">ราย</div>
          </div>
          <div style="background:var(--bg2);border-radius:8px;padding:10px 12px;border-left:3px solid #059669">
            <div style="font-size:10px;color:var(--text3);margin-bottom:4px">💰 ยอดขาย</div>
            <div style="font-size:18px;font-weight:800;color:#059669;line-height:1">${amt>=1000000?(amt/1000000).toFixed(1)+'M':amt>=1000?(amt/1000).toFixed(1)+'K':amt.toLocaleString()}</div>
            <div style="font-size:10px;color:var(--text3);margin-top:2px">บาท</div>
          </div>
        </div>
      </div>`;
    }).join('');

  const saleKpiEl = document.getElementById('d-sale-kpi');
  if(saleKpiEl) saleKpiEl.innerHTML = saleHtml || '<div class="no-data">ไม่มีข้อมูล</div>';
}

