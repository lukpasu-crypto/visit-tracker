function onHPeriod(){
  const p=document.getElementById('h-period').value;
  const isCustom=p==='custom';
  document.getElementById('h-from').style.display=isCustom?'':'none';
  document.getElementById('h-to-sep').style.display=isCustom?'':'none';
  document.getElementById('h-to').style.display=isCustom?'':'none';
  renderHistory();
}

function renderHistory(){
  const q=document.getElementById('h-search').value.toLowerCase();
  const emp=document.getElementById('h-emp').value;
  const type=document.getElementById('h-type').value;
  const prov=document.getElementById('h-prov').value;
  const period=document.getElementById('h-period')?document.getElementById('h-period').value:'all';
  const from=document.getElementById('h-from').value;
  const to=document.getElementById('h-to').value;
  const now=new Date();
  const todayStr=now.toISOString().slice(0,10);

  const data=DB.records.filter(r=>{
    if(emp&&r.employee!==emp)return false;
    if(type&&!r.types.includes(type))return false;
    if(prov&&r.province!==prov)return false;
    // Period filter
    if(period==='year'){if(new Date(r.date).getFullYear()!==now.getFullYear())return false;}
    else if(period==='month'){const d=new Date(r.date);if(d.getFullYear()!==now.getFullYear()||d.getMonth()!==now.getMonth())return false;}
    else if(period==='week'){const wk=new Date(now);wk.setDate(now.getDate()-7);if(new Date(r.date)<wk)return false;}
    else if(period==='day'){if(r.date!==todayStr)return false;}
    else if(period==='custom'){if(from&&r.date<from)return false;if(to&&r.date>to)return false;}
    if(q){const h=[r.customer,r.contact,r.province,r.zone||'',r.employee,r.product||'',r.resultNote||''].join(' ').toLowerCase();if(!h.includes(q))return false;}
    return true;
  });

  const wrap=document.getElementById('h-table');
  if(!data.length){wrap.innerHTML='<div class="no-data"><div>🗂</div>ไม่พบข้อมูล</div>';return;}

  wrap.innerHTML=`<table><thead><tr>
    <th>วันที่</th><th>พนักงาน</th><th>ลูกค้า / ผู้ติดต่อ</th><th class="mob-hide">จังหวัด/โซน</th>
    <th class="mob-hide">ประเภท</th><th>ผล</th><th style="text-align:right">ยอด</th>
    <th class="mob-hide">นัดถัดไป</th><th class="mob-hide">ภาพ/GPS</th><th class="mob-hide">Line</th><th></th>
  </tr></thead><tbody>
  ${data.map(r=>`<tr>
    <td style="white-space:nowrap">${fmtDate(r.date)}</td>
    <td>${r.employee}</td>
    <td>
      <div style="font-weight:600">${r.customer}</div>
      ${r.contact?`<div style="font-size:11px;color:var(--text3)">👤 ${r.contact}</div>`:''}
    </td>
    <td class="mob-hide">
      <div>${r.province}</div>
      ${r.zone?`<div style="font-size:11px;color:var(--text3)">${r.zone}</div>`:''}
    </td>
    <td class="mob-hide">${(r.types||[]).map(t=>`<span class="badge ${TYPE_BADGE[t]||'b-bl'}">${TYPE_LABEL[t]||t}</span><br>`).join('')}</td>
    <td>
      <div style="font-size:12px">${r.result||'—'}</div>
      ${r.resultNote?`<div style="font-size:11px;color:var(--text3);max-width:120px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${r.resultNote}">${r.resultNote}</div>`:''}
    </td>
    <td style="text-align:right">${r.amount>0?r.amount.toLocaleString():'—'}</td>
    <td class="mob-hide" style="font-size:11px;white-space:nowrap">${r.apptDate?fmtDate(r.apptDate)+(r.apptTime?'<br>'+r.apptTime:''):'—'}</td>
    <td class="mob-hide">
      ${r.photos&&r.photos.length?`<div class="thumb-grid">${r.photos.slice(0,3).map(p=>`<img class="thumb" src="${p}" onclick="openLB('${p}','')" title="คลิกดูรูป">`).join('')}${r.photos.length>3?`<div class="thumb-more">+${r.photos.length-3}</div>`:''}</div>`:''}
      ${r.gps?`<div style="font-size:10px;color:var(--text3);margin-top:2px">📍 ${r.gps.lat.toFixed(4)},${r.gps.lng.toFixed(4)}</div>`:''}
    </td>
    <td class="mob-hide"><span class="badge ${r.sent?'b-sent':'b-pending'}">${r.sent?'ส่งแล้ว':'รอส่ง'}</span></td>
    <td><button class="btn btn-outline btn-xs" onclick="openEdit(${r.id})">✏️</button></td>
  </tr>`).join('')}
  </tbody></table>`;
}

function fmtDate(d){
  if(!d) return '—';
  var s = String(d).trim();
  var m = s.match(/^(\d{4})-(\d{2})-(\d{2})/);
  if(m){
    var y = parseInt(m[1]);
    if(y > 2500) y = y - 543; // พ.ศ. → ค.ศ.
    var dt = new Date(y, parseInt(m[2])-1, parseInt(m[3]));
    if(isNaN(dt)) return s;
    // แสดงแบบสั้น DD/MM/YYYY (ค.ศ.)
    var dd = String(dt.getDate()).padStart(2,'0');
    var mm = String(dt.getMonth()+1).padStart(2,'0');
    return dd+'/'+mm+'/'+y;
  }
  return s;
}

