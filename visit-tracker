// SYNC FROM GOOGLE SHEETS → อัปเดต DB.records ทั้งหมด
// ══════════════════════════════════════════════
async function syncFromSheets(){
  const url = DB.settings.gasUrl;
  if(!url){ toast('⚠️ กรุณาตั้งค่า GAS URL ก่อน','err'); return; }

  const btn = document.getElementById('btn-sync-sheets');
  if(btn){ btn.disabled=true; btn.textContent='⏳ กำลัง Sync...'; }
  toast('☁️ กำลังโหลดข้อมูลจาก Sheets...','info');

  try{
    // ใช้ GET request เพื่อหลีกเลี่ยงปัญหา CORS และ action ไม่ผ่าน POST
    const getUrl = url + (url.includes('?')?'&':'?') + 'action=getRecordsFromSheet';
    const res = await gasGetWithRead(getUrl, 30000);
    if(!res.ok || !res.data || !res.data.success){
      toast('❌ Sync ไม่สำเร็จ: '+(res.err||res.data?.error||'ไม่ทราบสาเหตุ'),'err');
      return;
    }
    const sheetRecs = res.data.records || [];

    // รวม records: เอา Sheet เป็นหลัก เพิ่ม local ที่ยังไม่มีใน Sheet
    // Sheet = source of truth — ล้าง local แล้วใช้ Sheet แทนทั้งหมด
    DB.records = sheetRecs;
    dbSave();
    renderDashboard();
    buildCustomerList();
    toast(`✅ Sync สำเร็จ — ข้อมูลทั้งหมด ${DB.records.length} รายการ`,'ok');
  }catch(e){
    toast('❌ Sync error: '+e.message,'err');
    console.error('syncFromSheets:',e);
  }finally{
    if(btn){ btn.disabled=false; btn.textContent='☁️ Sync จาก Sheets'; }
  }
}
