// โหลดข้อมูลเดิมเข้าฟอร์ม ยกเว้นผลการเยี่ยม
function autofillFromHistory(){
  const val = document.getElementById('f-customer').value.trim().toLowerCase();
  const history = DB.records
    .filter(r=>(r.customer||'').trim().toLowerCase() === val)
    .sort((a,b)=>b.date.localeCompare(a.date));
  if(!history.length) return;

  // ถ้ามี dropdown ให้ใช้ index ที่เลือก
  const sel = document.getElementById('history-select');
  const idx = sel ? parseInt(sel.value)||0 : 0;
  const last = history[idx] || history[0];

  // ── autofill ฟิลด์ที่ต้องการ ──
  if(last.contact)  document.getElementById('f-contact').value  = last.contact;
  if(last.province){
    const pSel = document.getElementById('f-province');
    if(pSel) pSel.value = last.province;
  }
  if(last.zone) document.getElementById('f-zone').value = last.zone;

  // ประเภทลูกค้า (types)
  if(last.types && last.types.length){
    fTypes = [];
    document.querySelectorAll('[data-type]').forEach(el=>el.classList.remove('s-'+el.dataset.type));
    last.types.forEach(t=>{
      const el = document.querySelector(`[data-type="${t}"]`);
      if(el){ el.classList.add('s-'+t); fTypes.push(t); }
    });
  }

  // วัตถุประสงค์ — ตรวจอายุลูกค้า 1 ปี
  // ถ้าเยี่ยมครั้งแรกเกิน 1 ปี = ลูกค้าเก่า เพิ่ม followup
  // ถ้ายังไม่ถึง 1 ปี = ยังใหม่ เพิ่มแค่ result (ติดตามผล)
  const ONE_YEAR = 365 * 24 * 60 * 60 * 1000;
  const firstDate = history[history.length-1]?.date;
  const ageMs     = firstDate ? Date.now() - new Date(firstDate).getTime() : 0;

  // กฎวัตถุประสงค์อัตโนมัติ:
  // ไม่เคยเยี่ยม        → 👋 ลูกค้าใหม่
  // เยี่ยม < 1 ปี       → 👋 ลูกค้าใหม่ + 📋 ติดตามผล
  // เยี่ยม > 1 ปี       → 🔁 ลูกค้าเก่า
  const isFollowup = ageMs > 0 && ageMs < ONE_YEAR;
  const isOldCust  = ageMs >= ONE_YEAR;

  const basePurposes = (last.purposes||[]).filter(p=>p!=='new'&&p!=='followup'&&p!=='result');
  let newPurposes;
  if(isOldCust){
    // > 1 ปี = ลูกค้าเก่า
    newPurposes = [...new Set([...basePurposes, 'followup'])];
  } else if(isFollowup){
    // < 1 ปี = ลูกค้าใหม่ + ติดตามผล
    newPurposes = [...new Set([...basePurposes, 'new', 'result'])];
  } else {
    // ไม่เคยเยี่ยม = ลูกค้าใหม่
    newPurposes = [...new Set([...basePurposes, 'new'])];
  }
  fPurposes = [];
  document.querySelectorAll('[data-purpose]').forEach(el=>el.classList.remove('s-purpose'));
  newPurposes.forEach(p=>{
    const el = document.querySelector(`[data-purpose="${p}"]`);
    if(el){ el.classList.add('s-purpose'); fPurposes.push(p); }
  });

  // สินค้า/ธุรกรรม
  if(last.product)     document.getElementById('f-product').value      = last.product;
  if(last.txn){
