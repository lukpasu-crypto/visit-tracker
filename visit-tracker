<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ระบบบันทึกเยี่ยมลูกค้า v3</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4f6fb;--bg2:#ffffff;--bg3:#f0f2f7;
  --card:#ffffff;--card2:#f8f9fc;
  --border:#e2e6ef;--border2:#d0d6e3;
  --accent:#4f75ff;--accent-dim:rgba(79,117,255,.12);
  --accent2:#7c5cfc;
  --green:#16a34a;--green-dim:rgba(22,163,74,.12);
  --yellow:#d97706;--yellow-dim:rgba(217,119,6,.12);
  --orange:#ea580c;--red:#dc2626;--red-dim:rgba(220,38,38,.1);
  --text:#1a2035;--text2:#64748b;--text3:#94a3b8;
  --radius:10px;--shadow:0 4px 24px rgba(79,117,255,.10);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:15px;line-height:1.5;}

/* LAYOUT */
.app{display:flex;height:100vh;overflow:hidden;}
.sidebar{width:220px;min-width:220px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;box-shadow:2px 0 12px rgba(79,117,255,.07);}
.main{flex:1;overflow-y:auto;}

/* SIDEBAR */
.sb-logo{padding:18px 16px 14px;border-bottom:1px solid var(--border);}
.sb-logo h1{font-size:13px;font-weight:700;color:var(--accent);}
.sb-logo p{font-size:11px;color:var(--text3);margin-top:2px;}
.sb-nav{padding:10px 8px;flex:1;}
.nav-sec{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1px;padding:10px 8px 4px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:6px;cursor:pointer;color:var(--text2);font-size:13.5px;font-weight:500;transition:all .15s;margin-bottom:1px;user-select:none;}
.nav-item:hover{background:var(--bg3);color:var(--text);}
.nav-item.active{background:var(--accent-dim);color:var(--accent);}
.sb-bottom{padding:10px 8px;border-top:1px solid var(--border);}
.conn-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px;}
.conn-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;font-size:11px;}
.conn-row:last-child{margin-bottom:0;}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;background:var(--text3);}
.dot.ok{background:var(--green);}

/* PAGE */
.page{display:none;padding:22px 26px;}
.page.active{display:block;}
.ph{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:18px;}
.ph h2{font-size:20px;font-weight:700;}
.ph p{color:var(--text2);font-size:12px;margin-top:3px;}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:0 2px 8px rgba(79,117,255,.05);}
.ch{font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:14px;}

/* FORM */
.fg{display:flex;flex-direction:column;gap:5px;}
.fg label{font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.4px;}
.fg label .req{color:var(--red);}
.fi,.fs,.ft{background:var(--bg3);border:1.5px solid var(--border);border-radius:7px;color:var(--text);padding:8px 11px;font-size:14px;font-family:'Sarabun',sans-serif;width:100%;transition:border-color .15s;}
.fi:focus,.fs:focus,.ft:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-dim);}
.ft{resize:vertical;min-height:70px;}
.fs option{background:var(--bg3);}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:12px;}
.full{grid-column:1/-1;}

/* CHIPS */
.chips{display:flex;flex-wrap:wrap;gap:7px;}
.chip{padding:5px 13px;border-radius:20px;border:1px solid var(--border2);cursor:pointer;font-size:13px;font-weight:500;color:var(--text2);background:var(--bg3);transition:all .15s;user-select:none;}
.chip:hover{border-color:var(--accent);color:var(--accent);}
.chip.s-tech{background:rgba(219,109,40,.15);border-color:var(--orange);color:var(--orange);}
.chip.s-retail{background:var(--green-dim);border-color:var(--green);color:var(--green);}
.chip.s-wholesale{background:rgba(8,145,178,.15);border-color:#0891b2;color:#0891b2;}
.chip.s-proj{background:rgba(188,140,255,.15);border-color:var(--accent2);color:var(--accent2);}
.chip.s-gov{background:rgba(210,153,34,.15);border-color:var(--yellow);color:var(--yellow);}
.chip.s-purpose{background:rgba(56,139,253,.12);border-color:var(--accent);color:var(--accent);}
.chip.s-result{background:var(--green-dim);border-color:var(--green);color:var(--green);}

/* STARS */
.stars{display:flex;gap:5px;}
.star{font-size:20px;cursor:pointer;color:var(--border2);transition:color .1s;line-height:1;}
.star.on{color:var(--yellow);}

/* BUTTONS */
.btn-row{display:flex;gap:9px;flex-wrap:wrap;}
.btn{padding:9px 18px;border-radius:7px;border:none;font-family:'Sarabun',sans-serif;font-size:13.5px;font-weight:600;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;justify-content:center;gap:6px;white-space:nowrap;}
.btn:disabled{opacity:.45;cursor:not-allowed;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover:not(:disabled){background:#1f6feb;}
.btn-green{background:var(--green);color:#0d1117;}
.btn-green:hover:not(:disabled){background:#2ea043;}
.btn-outline{background:transparent;border:1px solid var(--border2);color:var(--text2);}
.btn-outline:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
.btn-red{background:var(--red-dim);border:1px solid var(--red);color:var(--red);}
.btn-red:hover:not(:disabled){background:var(--red);color:#fff;}
.btn-sm{padding:5px 11px;font-size:12px;}
.btn-xs{padding:3px 8px;font-size:11px;}

/* BADGES */
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;}
.b-biz{background:var(--accent-dim);color:var(--accent);}
.b-tech{background:rgba(219,109,40,.15);color:var(--orange);}
.b-retail{background:var(--green-dim);color:var(--green);}
.b-proj{background:rgba(188,140,255,.15);color:var(--accent2);}
.b-gov{background:var(--yellow-dim);color:var(--yellow);}
.b-wholesale{background:rgba(8,145,178,.15);color:#0891b2;}
.b-sent{background:var(--green-dim);color:var(--green);}
.b-pending{background:var(--yellow-dim);color:var(--yellow);}

/* NOTICE */
.notice{border-radius:8px;padding:10px 14px;font-size:13px;display:flex;align-items:center;gap:9px;margin-bottom:12px;}
.n-yellow{background:var(--yellow-dim);border:1px solid rgba(210,153,34,.4);color:#e3b341;}
.n-blue{background:var(--accent-dim);border:1px solid rgba(56,139,253,.4);color:var(--accent);}
.n-green{background:var(--green-dim);border:1px solid rgba(63,185,80,.4);color:var(--green);}

/* PHOTO GRID */
.photo-drop{border:2px dashed var(--border2);border-radius:10px;padding:24px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg3);position:relative;}
.photo-drop:hover,.photo-drop.drag{border-color:var(--accent);background:var(--accent-dim);}
.photo-drop p{color:var(--text3);font-size:13px;margin-top:6px;}
.photo-drop input{position:absolute;inset:0;opacity:0;cursor:pointer;}
.photo-grid{display:grid;gap:8px;margin-top:12px;}
.photo-grid.n1{grid-template-columns:1fr;}
.photo-grid.n2{grid-template-columns:1fr 1fr;}
.photo-grid.n3{grid-template-columns:1fr 1fr 1fr;}
.photo-grid.n4{grid-template-columns:1fr 1fr 1fr 1fr;}
.photo-grid.n5,.photo-grid.n6{grid-template-columns:repeat(3,1fr);}
.photo-item{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:1;background:var(--bg3);}
.photo-item img{width:100%;height:100%;object-fit:cover;}
.photo-del{position:absolute;top:5px;right:5px;background:rgba(0,0,0,.7);border:none;color:#fff;border-radius:50%;width:22px;height:22px;font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;}
.photo-del:hover{background:var(--red);}
.gps-badge{position:absolute;bottom:5px;left:5px;background:rgba(0,0,0,.75);color:#fff;font-size:10px;border-radius:4px;padding:2px 6px;display:flex;align-items:center;gap:3px;}

/* GPS status */
.gps-row{display:flex;align-items:center;gap:10px;margin-top:10px;flex-wrap:wrap;}
.gps-info{background:var(--bg3);border:1px solid var(--border);border-radius:7px;padding:7px 12px;font-size:12px;color:var(--text2);flex:1;}
.gps-info.got{border-color:var(--green);color:var(--green);}
.gps-info.err{border-color:var(--red);color:var(--red);}

/* APPOINTMENT */
.appt-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px;}
.appt-box .g2{margin-bottom:0;}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:relative;overflow:hidden;}
.stat::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--ac,var(--accent));}
.stat-lbl{font-size:10.5px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;font-weight:700;}
.stat-val{font-size:26px;font-weight:800;margin:4px 0 2px;}
.stat-sub{font-size:11px;color:var(--text3);}

/* CHARTS */
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.cbox{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:0 2px 8px rgba(79,117,255,.06);}
.ctitle{font-size:11px;font-weight:700;color:var(--text2);margin-bottom:12px;text-transform:uppercase;letter-spacing:.5px;}
.bar-chart{display:flex;align-items:flex-end;gap:5px;height:110px;}
.bw{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;height:100%;justify-content:flex-end;}
.bv{font-size:9.5px;color:var(--text2);font-weight:600;}
.b{width:100%;border-radius:3px 3px 0 0;min-height:2px;transition:height .5s ease;}
.bl{font-size:9px;color:var(--text3);}
.donut-wrap{display:flex;align-items:center;gap:16px;}
.dleg{flex:1;display:flex;flex-direction:column;gap:7px;}
.dleg-item{display:flex;align-items:center;gap:7px;font-size:12px;}
.dleg-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.res-item{display:flex;align-items:center;gap:9px;margin-bottom:7px;}
.res-name{flex:0 0 120px;font-size:11.5px;color:var(--text2);}
.res-bg{flex:1;background:var(--bg3);border-radius:3px;height:7px;overflow:hidden;}
.res-bar{height:100%;border-radius:3px;background:var(--green);}
.res-cnt{font-size:11.5px;font-weight:700;width:22px;text-align:right;}

/* FILTER */
.frow{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:14px;}
.frow .fi,.frow .fs{padding:6px 10px;font-size:12.5px;}

/* TABLE */
.tbl-wrap{overflow-x:auto;border:1px solid var(--border);border-radius:var(--radius);}
table{width:100%;border-collapse:collapse;}
th{background:var(--bg3);color:var(--text3);font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:9px 12px;text-align:left;border-bottom:1px solid var(--border);}
td{padding:10px 12px;font-size:12.5px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--bg3);}
.no-data{text-align:center;padding:40px;color:var(--text3);font-size:13px;}

/* PHOTO THUMB in table */
.thumb-grid{display:flex;gap:3px;flex-wrap:wrap;}
.thumb{width:34px;height:34px;border-radius:4px;object-fit:cover;border:1px solid var(--border);}
.thumb-more{width:34px;height:34px;border-radius:4px;background:var(--bg3);border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text3);font-weight:700;}

/* MODAL */
.overlay{display:none;position:fixed;inset:0;background:rgba(30,40,80,.5);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(3px);}
.overlay.open{display:flex;}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:24px;width:680px;max-width:96vw;max-height:92vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.18);}
.modal-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;}
.modal-hd h3{font-size:16px;font-weight:700;}
.modal-close{background:none;border:none;color:var(--text3);font-size:18px;cursor:pointer;padding:4px;}
.modal-close:hover{color:var(--text);}

/* LIGHTBOX */
.lb-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:500;align-items:center;justify-content:center;flex-direction:column;}
.lb-overlay.open{display:flex;}
.lb-img{max-width:90vw;max-height:80vh;border-radius:8px;object-fit:contain;}
.lb-close{position:absolute;top:16px;right:20px;background:none;border:none;color:#fff;font-size:26px;cursor:pointer;}
.lb-info{color:rgba(255,255,255,.6);font-size:12px;margin-top:12px;}

/* SETTINGS */
.sett-sec{margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid var(--border);}
.sett-sec:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.sett-sec h3{font-size:13px;font-weight:700;color:var(--text2);margin-bottom:14px;}
.sett-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid rgba(48,54,61,.5);}
.sett-row:last-child{border-bottom:none;}
.sett-key{font-size:13px;font-weight:500;}
.sett-desc{font-size:11px;color:var(--text3);margin-top:1px;}
.tog{position:relative;width:38px;height:21px;flex-shrink:0;}
.tog input{opacity:0;width:0;height:0;}
.tog-sl{position:absolute;inset:0;background:var(--border2);border-radius:11px;cursor:pointer;transition:.2s;}
.tog-sl::before{content:'';position:absolute;width:15px;height:15px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s;}
.tog input:checked+.tog-sl{background:var(--accent);}
.tog input:checked+.tog-sl::before{transform:translateX(17px);}
.info-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:14px;font-size:12.5px;color:var(--text2);line-height:1.7;}
.info-box code{background:var(--card2);border:1px solid var(--border2);border-radius:4px;padding:1px 6px;font-size:11.5px;color:var(--accent2);}

/* ADMIN LOCK */
.admin-only{display:none;}
.admin-mode .admin-only{display:block;}
.admin-mode .admin-only-flex{display:flex;}
.lock-overlay{position:relative;}
.lock-overlay::after{content:'🔒 เฉพาะ Admin';position:absolute;inset:0;background:rgba(244,246,251,.88);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;color:var(--text2);pointer-events:none;z-index:2;}
.admin-mode .lock-overlay::after{display:none;}
.admin-bar{background:var(--accent);color:#fff;padding:8px 16px;border-radius:8px;display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;font-size:13px;}
.admin-bar.locked{background:var(--text2);}

/* TAGS */
.tag-list{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;}
.tag{display:flex;align-items:center;gap:5px;background:var(--bg3);border:1px solid var(--border2);border-radius:6px;padding:4px 9px;font-size:12px;}
.tag-del{background:none;border:none;color:var(--text3);cursor:pointer;font-size:14px;line-height:1;padding:0;}
.tag-del:hover{color:var(--red);}

/* SPIN */
.spin{display:inline-block;width:14px;height:14px;border:2px solid transparent;border-top-color:currentColor;border-radius:50%;animation:spin .6s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* DASHBOARD RESPONSIVE */
.dash-row2{display:grid;grid-template-columns:1fr 180px;gap:12px;align-items:start;}
@media(max-width:600px){
  .dash-row2{grid-template-columns:1fr;}
  .chart-row{grid-template-columns:1fr;}
  .kpi-grid{grid-template-columns:repeat(2,1fr)!important;}
}

/* PROGRESS BAR */
#save-progress{display:none;margin-top:12px;border-radius:8px;overflow:hidden;background:var(--bg3);border:1px solid var(--border);}
.prog-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px 6px;}
.prog-title{font-size:13px;font-weight:600;color:var(--text);}
.prog-pct{font-size:12px;font-weight:700;color:var(--accent);}
.prog-bar-bg{height:6px;background:var(--bg3);margin:0 14px 10px;}
.prog-bar-fill{height:6px;background:var(--accent);border-radius:3px;transition:width .4s ease;width:0%;}
.prog-steps{display:flex;flex-direction:column;gap:0;padding:0 14px 12px;}
.prog-step{display:flex;align-items:center;gap:8px;padding:4px 0;font-size:12px;color:var(--text3);border-top:1px solid var(--border);}
.prog-step:first-child{border-top:none;}
.prog-step.done{color:var(--green);}
.prog-step.active{color:var(--accent);font-weight:600;}
.prog-step.err{color:var(--red);}
.prog-icon{font-size:13px;width:18px;text-align:center;flex-shrink:0;}

/* TOAST */
#toast{position:fixed;bottom:20px;right:20px;z-index:999;display:flex;flex-direction:column;gap:7px;}
.ti{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:11px 16px;font-size:12.5px;color:var(--text);box-shadow:0 4px 20px rgba(0,0,0,.15);animation:tIn .25s ease;max-width:300px;display:flex;align-items:center;gap:8px;}
.ti.ok{border-color:var(--green);}
.ti.err{border-color:var(--red);}
@keyframes tIn{from{opacity:0;transform:translateX(30px);}to{opacity:1;transform:translateX(0);}}

/* ══ KPI CARDS ══ */
.kpi-grid{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:12px;
  margin-bottom:18px;
}
.kpi-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:18px 16px 16px;
  position:relative;
  overflow:hidden;
  transition:transform .15s,box-shadow .15s;
}
.kpi-card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.45);}
.kpi-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.kpi-icon-wrap{
  width:40px;height:40px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0;
}
.kpi-label{font-size:11px;font-weight:700;color:var(--text3);letter-spacing:.3px;margin-bottom:6px;line-height:1.3;}
.kpi-val{font-size:30px;font-weight:800;color:var(--text);line-height:1;margin-bottom:4px;}
.kpi-unit{font-size:11px;color:var(--text3);}
.kpi-stripe{position:absolute;bottom:0;left:0;right:0;height:3px;}

/* ══ EMP RANK ══ */
.emp-rank-row{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid rgba(48,54,61,.5);}
.emp-rank-row:last-child{border-bottom:none;}
.emp-rank-no{font-size:13px;font-weight:800;width:24px;text-align:center;flex-shrink:0;}
.emp-rank-name{flex:1;font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.emp-rank-bars{flex:2;display:flex;flex-direction:column;gap:4px;}
.emp-bar-row{display:flex;align-items:center;gap:6px;}
.emp-bar-bg{flex:1;height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;}
.emp-bar-fill{height:100%;border-radius:3px;transition:width .6s ease;}
.emp-bar-lbl{font-size:10px;color:var(--text3);width:32px;text-align:right;flex-shrink:0;}
.emp-rank-stats{display:flex;flex-direction:column;gap:2px;align-items:flex-end;flex-shrink:0;min-width:48px;}
.emp-stat-num{font-size:14px;font-weight:800;}
.emp-stat-sub{font-size:10px;color:var(--text3);}

::-webkit-scrollbar{width:5px;height:5px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}

/* ══ MOBILE RESPONSIVE ══ */
@media(max-width:1100px){
  .kpi-grid{grid-template-columns:repeat(3,1fr);}
}

.mob-nav{display:none;}

@media(max-width:768px){
  /* Hide desktop sidebar */
  .sidebar{ display:none !important; }

  /* Main fills full width, add padding-bottom for bottom nav */
  .main{ width:100%; padding-top:70px; }
  .app{ flex-direction:column; height:100vh; }

  /* Page padding tighter */
  .page{ padding:16px 14px; }

  /* Bottom navigation bar */
  .mob-nav{
    display:flex !important;
    position:fixed;top:0;left:0;right:0;
    background:var(--bg2);
    border-bottom:1px solid var(--border);
    z-index:100;
    padding:0;
    box-shadow:0 2px 16px rgba(79,117,255,.10);
  }
  .mob-nav-item{
    flex:1;display:flex;flex-direction:column;align-items:center;
    justify-content:center;padding:10px 4px 8px;
    font-size:9.5px;font-weight:600;color:var(--text3);
    cursor:pointer;border:none;background:none;
    gap:4px;transition:color .15s;
    font-family:'Sarabun',sans-serif;
  }
  .mob-nav-item span.ico{font-size:20px;line-height:1;}
  .mob-nav-item.active{color:var(--accent);}
  .mob-nav-item.active .mob-indicator{
    width:28px;height:3px;background:var(--accent);
    border-radius:2px;position:absolute;bottom:0;
  }
  .mob-nav-item{position:relative;}

  /* KPI grid */
  .kpi-grid{grid-template-columns:repeat(3,1fr) !important;gap:9px;}
  .kpi-val{font-size:22px;}
  .kpi-card{padding:14px 12px 14px;}

  /* Charts */
  .chart-row{grid-template-columns:1fr;}
  .g2,.g3,.g4{grid-template-columns:1fr;}

  /* Table scroll */
  .tbl-wrap{font-size:11.5px;}
  th,td{padding:8px 9px;}

  /* Filter row wrap */
  .frow{flex-wrap:wrap;}
  .frow .fi,.frow .fs{min-width:0;flex:1;}

  /* Cards */
  .card{padding:14px;}

  /* Chips smaller */
  .chip{font-size:12px;padding:5px 10px;}

  /* hide non-essential table cols on mobile */
  .mob-hide{display:none !important;}
}


</style>
</head>
<body>
<div class="app">

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <div class="sb-logo">
    <h1>📋 เยี่ยมลูกค้า</h1>
    <p>Customer Visit System v3</p>
  </div>
  <nav class="sb-nav">
    <div class="nav-sec">บันทึก</div>
    <div class="nav-item active" data-page="record" onclick="nav(this)"><span>✏️</span>บันทึกการเยี่ยม</div>
    <div class="nav-sec">รายงาน</div>
    <div class="nav-item" data-page="dashboard" onclick="nav(this)"><span>📊</span>Dashboard</div>
    <div class="nav-item" data-page="history" onclick="nav(this)"><span>🗂</span>ประวัติการเยี่ยม</div>
    <div class="nav-sec">จัดการ</div>
    <div class="nav-item" data-page="settings" onclick="nav(this)"><span>⚙️</span>ตั้งค่าการเชื่อมต่อ</div>
  </nav>
  <div class="sb-bottom">
    <div class="conn-box">
      <div class="conn-row"><div class="dot" id="dot-sheets"></div><span id="lbl-sheets" style="color:var(--text2)">Google Sheets</span></div>
      <div class="conn-row"><div class="dot" id="dot-line"></div><span id="lbl-line" style="color:var(--text2)">Line Messaging</span></div>
    </div>
  </div>
</aside>

<!-- ══ MOBILE BOTTOM NAV ══ -->
<nav class="mob-nav">
  <button class="mob-nav-item active" data-page="record" onclick="mobNav(this)">
    <div class="mob-indicator"></div>
    <span class="ico">✏️</span>บันทึก
  </button>
  <button class="mob-nav-item" data-page="dashboard" onclick="mobNav(this)">
    <div class="mob-indicator" style="display:none"></div>
    <span class="ico">📊</span>Dashboard
  </button>
  <button class="mob-nav-item" data-page="history" onclick="mobNav(this)">
    <div class="mob-indicator" style="display:none"></div>
    <span class="ico">🗂</span>ประวัติ
  </button>
  <button class="mob-nav-item" data-page="settings" onclick="mobNav(this)">
    <div class="mob-indicator" style="display:none"></div>
    <span class="ico">⚙️</span>ตั้งค่า
  </button>
</nav>

<!-- ══ MAIN ══ -->
<main class="main">

<!-- ━━ PAGE: RECORD ━━ -->
<div class="page active" id="page-record">
  <div class="ph"><div><h2>✏️ บันทึกการเยี่ยมลูกค้า</h2><p>กรอกข้อมูลให้ครบก่อนบันทึก</p></div></div>

  <div id="pending-bar" style="display:none" class="notice n-yellow">
    ⏰ มีรายการรอส่ง Line <strong id="pending-cnt">0</strong> รายการ — จะส่งอัตโนมัติ 19:00 น.
    <button class="btn btn-outline btn-xs" style="margin-left:auto" onclick="sendPendingNow()">ส่งทันที</button>
  </div>

  <!-- ผู้บันทึก & วันที่ -->
  <div class="card">
    <div class="ch">👤 ผู้บันทึก & วันที่</div>
    <div class="g2">
      <div class="fg"><label>พนักงาน <span class="req">*</span></label>
        <select class="fs" id="f-emp"><option value="">-- เลือกพนักงาน --</option></select></div>
      <div class="fg"><label>วันที่เยี่ยม <span class="req">*</span></label>
        <input type="date" class="fi" id="f-date"></div>
    </div>
  </div>

  <!-- ข้อมูลลูกค้า -->
  <div class="card">
    <div class="ch">🏢 ข้อมูลลูกค้า</div>
    <div class="g2">
      <div class="fg"><label>ชื่อลูกค้า / ร้านค้า <span class="req">*</span></label>
        <input type="text" class="fi" id="f-customer" placeholder="ชื่อลูกค้าหรือร้านค้า..."
               oninput="onCustomerInput(this.value)" autocomplete="off" list="customer-list">
        <datalist id="customer-list"></datalist>
        <div id="customer-alert" style="display:none;margin-top:6px;padding:8px 12px;background:#fef3c7;border:1px solid #d97706;border-radius:6px;font-size:12px;color:#92400e"></div>
        </div>
      <div class="fg"><label>ชื่อผู้ติดต่อ</label>
        <input type="text" class="fi" id="f-contact" placeholder="ชื่อ-นามสกุล ผู้ติดต่อ..."></div>
      <div class="fg"><label>จังหวัด <span class="req">*</span></label>
        <select class="fs" id="f-province"><option value="">-- เลือกจังหวัด --</option></select></div>
      <div class="fg"><label>พื้นที่ / โซน</label>
        <input type="text" class="fi" id="f-zone" placeholder="เช่น เมือง, ลาดพร้าว, โซนเหนือ..."></div>
    </div>
    <div style="margin-top:13px">
      <div class="fg" style="margin-bottom:7px"><label>ประเภทลูกค้า (เลือกได้หลายประเภท) <span class="req">*</span></label></div>
      <div class="chips" id="type-chips">
        <div class="chip" data-type="tech"      onclick="toggleChip(this,'tech'     )">🔧 ช่างติดตั้ง/ซ่อมบำรุง</div>
        <div class="chip" data-type="retail"    onclick="toggleChip(this,'retail'   )">🛍 ร้านค้าปลีก</div>
        <div class="chip" data-type="wholesale" onclick="toggleChip(this,'wholesale')">📦 ร้านค้าส่ง</div>
        <div class="chip" data-type="proj"      onclick="toggleChip(this,'proj'     )">🏗 โปรเจค/โครงงานก่อสร้าง</div>
        <div class="chip" data-type="gov"       onclick="toggleChip(this,'gov'      )">🏛 หน่วยงานราชการ</div>
      </div>
    </div>
  </div>

  <!-- รายละเอียดการเยี่ยม -->
  <div class="card">
    <div class="ch">📋 รายละเอียดการเยี่ยม</div>

    <!-- วัตถุประสงค์ — Chips เลือกได้หลายอย่าง -->
    <div class="fg" style="margin-bottom:14px">
      <label>🎯 วัตถุประสงค์ <span class="req">*</span></label>
      <div class="chips" id="purpose-chips" style="margin-top:8px">
        <div class="chip" data-purpose="new"      onclick="togglePurpose(this)">👋 ลูกค้าใหม่</div>
        <div class="chip" data-purpose="followup" onclick="togglePurpose(this)">🔁 ติดตามลูกค้าเก่า</div>
        <div class="chip" data-purpose="present"  onclick="togglePurpose(this)">📣 นำเสนอสินค้า/บริการ</div>
        <div class="chip" data-purpose="result"   onclick="togglePurpose(this)">📋 ติดตามผล</div>
        <div class="chip" data-purpose="aftersale"onclick="togglePurpose(this)">🔧 แก้ปัญหา/After Sales</div>
        <div class="chip" data-purpose="contract" onclick="togglePurpose(this)">📄 ต่ออายุสัญญา</div>
        <div class="chip" data-purpose="relation" onclick="togglePurpose(this)">🤝 สร้างความสัมพันธ์</div>
        <div class="chip" data-purpose="survey"   onclick="togglePurpose(this)">🔍 สำรวจความต้องการ</div>
        <div class="chip" data-purpose="other"    onclick="togglePurpose(this)">💬 อื่นๆ</div>
      </div>
    </div>

    <!-- ผลการเยี่ยม -->
    <div class="fg">
      <label>📝 ผลการเยี่ยม <span class="req">*</span></label>
      <textarea class="ft" id="f-result-note" placeholder="สรุปผลพูดคุย ความสนใจ หรือข้อตกลงที่ได้..." style="min-height:90px"></textarea>
    </div>
    <!-- สถานะผลการเยี่ยม — Chips -->
    <div class="fg" style="margin-top:14px">
      <label>สถานะผลการเยี่ยม</label>
      <div class="chips" id="result-chips" style="margin-top:8px">
        <div class="chip" data-result="success"  onclick="toggleResult(this)">✅ สำเร็จ</div>
        <div class="chip" data-result="closed"   onclick="toggleResult(this)">🎯 ปิดการขาย</div>
        <div class="chip" data-result="followup" onclick="toggleResult(this)">🔄 ต้องติดตามต่อ</div>
        <div class="chip" data-result="fail"     onclick="toggleResult(this)">❌ ไม่สำเร็จ</div>
        <div class="chip" data-result="appt"     onclick="toggleResult(this)">📅 นัดครั้งหน้า</div>
      </div>
    </div>
    <div class="fg" style="margin-top:12px">
      <label>ยอดขาย (บาท)</label>
      <input type="number" class="fi" id="f-amount" placeholder="0" min="0" style="max-width:220px">
    </div>
  </div>

  <!-- นัดหมายครั้งถัดไป -->
  <div class="card">
    <div class="ch">📅 นัดหมายครั้งถัดไป</div>
    <div class="g3">
      <div class="fg"><label>วันที่นัด</label>
        <input type="date" class="fi" id="f-appt-date"></div>
      <div class="fg"><label>เวลา</label>
        <input type="time" class="fi" id="f-appt-time"></div>
      <div class="fg"><label>วัตถุประสงค์การนัด</label>
        <input type="text" class="fi" id="f-appt-note" placeholder="เช่น ติดตามใบเสนอราคา..."></div>
    </div>
  </div>

  <!-- สินค้า -->
  <div class="card">
    <div class="ch">📦 สินค้าที่ลูกค้าสนใจ / สั่งซื้อ / นำเสนอ</div>
    <div class="g2">
      <div class="fg"><label>สินค้า / รุ่น / รหัส</label>
        <input type="text" class="fi" id="f-product" placeholder="ชื่อสินค้า รุ่น รหัสสินค้า..."></div>
      <div class="fg"><label>ประเภทธุรกรรม</label>
        <select class="fs" id="f-txn">
          <option value="">-- เลือก --</option>
          <option>นำเสนอ/แนะนำ</option>
          <option>ลูกค้าสนใจ</option>
          <option>ใบเสนอราคา</option>
          <option>สั่งซื้อแล้ว</option>
          <option>ติดตามการส่ง</option>
        </select>
      </div>
      <div class="fg full"><label>รายละเอียดสินค้าเพิ่มเติม</label>
        <textarea class="ft" id="f-product-note" placeholder="จำนวน ราคา เงื่อนไข หรือรายการสินค้า..." style="min-height:60px"></textarea>
      </div>
    </div>
  </div>

  <!-- รูปภาพร้านค้า + GPS -->
  <div class="card">
    <div class="ch">📸 รูปภาพร้านค้า</div>

    <!-- ปุ่มเลือกรูป 2 แบบ -->
    <div style="display:flex;gap:10px;margin-bottom:10px">
      <button type="button" class="btn btn-outline" style="flex:1;padding:14px;border-radius:10px;flex-direction:column;gap:6px;height:auto"
        onclick="document.getElementById('photo-camera').click()">
        <div style="font-size:24px">📷</div>
        <div style="font-size:12px;font-weight:600">ถ่ายรูป</div>
        <div style="font-size:10px;color:var(--text3)">เปิดกล้อง</div>
      </button>
      <button type="button" class="btn btn-outline" style="flex:1;padding:14px;border-radius:10px;flex-direction:column;gap:6px;height:auto"
        onclick="document.getElementById('photo-gallery').click()">
        <div style="font-size:24px">🖼</div>
        <div style="font-size:12px;font-weight:600">เลือกรูป</div>
        <div style="font-size:10px;color:var(--text3)">จากอัลบั้ม</div>
      </button>
    </div>
    <!-- Drop zone (desktop) -->
    <div class="photo-drop" id="photo-drop"
      onclick="document.getElementById('photo-gallery').click()"
      ondragover="onDragOver(event)" ondrop="onDrop(event)" ondragleave="onDragLeave(event)">
      <div style="font-size:22px">📂</div>
      <p>หรือลากวางรูปที่นี่<br><span style="font-size:11px;color:var(--text3)">รองรับ JPG, PNG, HEIC — หลายรูปได้</span></p>
    </div>
    <!-- Input: ถ่ายรูปจากกล้อง -->
    <input type="file" id="photo-camera" accept="image/*" capture="environment"
      multiple onchange="onPhotoSelect(event)" style="display:none">
    <!-- Input: เลือกจากแกลลอรี่ -->
    <input type="file" id="photo-gallery" accept="image/*"
      multiple onchange="onPhotoSelect(event)" style="display:none">
    <!-- legacy hidden input -->
    <input type="file" id="photo-input" accept="image/*" multiple onchange="onPhotoSelect(event)" style="display:none">

    <div id="photo-grid-wrap" style="display:none">
      <div class="photo-grid" id="photo-grid"></div>
    </div>

    <!-- GPS status — แสดงอัตโนมัติหลังเลือกรูป -->
    <div id="gps-display" class="gps-info" style="display:none;margin-top:8px"></div>
    <button id="btn-gps" style="display:none"></button>
    <button id="btn-clear-gps" style="display:none"></button>
  </div>

  <!-- ปุ่มบันทึก -->
  <div class="card">
    <div class="ch">📤 บันทึกและส่งรายงาน</div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="doSave('queue')" id="btn-save">💾 บันทึก (ส่ง Line 19:00 น.)</button>
      <button class="btn btn-green" onclick="doSave('now')" id="btn-send">📲 บันทึก + ส่ง Line ทันที</button>
      <button class="btn btn-outline" onclick="resetForm()">🔄 ล้างฟอร์ม</button>
    </div>
    <!-- Progress Bar -->
    <div id="save-progress">
      <div class="prog-header">
        <span class="prog-title" id="prog-title">กำลังบันทึก...</span>
        <span class="prog-pct" id="prog-pct">0%</span>
      </div>
      <div class="prog-bar-bg"><div class="prog-bar-fill" id="prog-fill"></div></div>
      <div class="prog-steps" id="prog-steps"></div>
    </div>
  </div>
</div>

<!-- ━━ PAGE: DASHBOARD ━━ -->
<div class="page" id="page-dashboard">

  <!-- Header + Filter -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;flex-wrap:wrap">
    <div><h2 style="font-size:20px;font-weight:700">📊 Dashboard ภาพรวม</h2>
      <p style="color:var(--text2);font-size:12px;margin-top:3px">สรุปผลการเยี่ยมลูกค้าและ KPI พนักงาน</p></div>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
      <select class="fs" id="d-filter" onchange="onDFilt()" style="font-size:12.5px;padding:6px 10px;width:auto">
        <option value="year">ทั้งปี</option>
        <option value="q1">ไตรมาส 1</option><option value="q2">ไตรมาส 2</option>
        <option value="q3">ไตรมาส 3</option><option value="q4">ไตรมาส 4</option>
        <option value="month">เดือนนี้</option><option value="week">สัปดาห์นี้</option>
        <option value="day">วันนี้</option><option value="custom">กำหนดเอง</option>
      </select>
      <select class="fs" id="d-year" onchange="renderDashboard()" style="font-size:12.5px;padding:6px 10px;width:auto"></select>
      <select class="fs" id="d-month" onchange="renderDashboard()" style="font-size:12.5px;padding:6px 10px;width:auto">
        <option value="0">ทุกเดือน</option>
        <option value="1">ม.ค.</option><option value="2">ก.พ.</option><option value="3">มี.ค.</option>
        <option value="4">เม.ย.</option><option value="5">พ.ค.</option><option value="6">มิ.ย.</option>
        <option value="7">ก.ค.</option><option value="8">ส.ค.</option><option value="9">ก.ย.</option>
        <option value="10">ต.ค.</option><option value="11">พ.ย.</option><option value="12">ธ.ค.</option>
      </select>
      <input type="date" class="fi" id="d-from" style="display:none;font-size:12.5px;padding:6px 10px" onchange="renderDashboard()">
      <input type="date" class="fi" id="d-to" style="display:none;font-size:12.5px;padding:6px 10px" onchange="renderDashboard()">
      <button class="btn btn-outline btn-sm" onclick="renderDashboard()">🔄 โหลดใหม่</button>
      <button class="btn btn-primary btn-sm" onclick="syncFromSheets()" id="btn-sync-sheets">☁️ Sync จาก Sheets</button>
      <span id="sync-status" style="display:none;font-size:11px;color:var(--green);font-weight:500"></span>
    </div>
  </div>

  <!-- ── ส่วนที่ 1: KPI รวม (การ์ดแถวบน) ── -->
  <div id="d-kpi-cards" class="kpi-grid" style="margin-bottom:16px"></div>

  <!-- ── ส่วนที่ 2: กราฟรายเดือน + ประเภทลูกค้า ── -->
  <!-- กราฟเดือน + ประเภทลูกค้า: มือถือ = แนวตั้ง, PC = side by side -->
  <div class="dash-row2" style="margin-bottom:14px">
    <div class="cbox" style="margin-bottom:0;min-width:0">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px">
        <div class="ctitle" style="margin-bottom:0;font-size:13px">📅 การเยี่ยมรายเดือน</div>
        <select class="fs" id="d-emp-filter" onchange="renderDashboard()" style="font-size:11px;padding:4px 8px;width:auto">
          <option value="">ทุกคน</option>
        </select>
      </div>
      <div style="overflow-x:auto;-webkit-overflow-scrolling:touch">
        <svg id="ch-mon" height="150" style="min-width:300px;max-width:100%;width:100%;display:block"></svg>
        <div id="ch-mon-legend" style="display:flex;gap:10px;flex-wrap:wrap;margin-top:6px;font-size:10px;padding:0 4px"></div>
      </div>
    </div>
    <div class="cbox" style="margin-bottom:0;min-width:0">
      <div class="ctitle" style="font-size:13px">🏷 ประเภทลูกค้า</div>
      <div class="donut-wrap" style="justify-content:flex-start;gap:12px">
        <svg id="ch-donut" viewBox="0 0 100 100" width="90" height="90" style="flex-shrink:0"></svg>
        <div class="dleg" id="ch-dleg" style="font-size:11px"></div>
      </div>
    </div>
  </div>

  <!-- ── ส่วนที่ 3: อันดับพนักงาน (KPI ยอดขาย) + Top จังหวัด ── -->
  <div class="chart-row" style="margin-bottom:14px;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px">
    <div class="cbox">
      <div class="ctitle">🏆 อันดับพนักงาน (KPI ยอดขาย)</div>
      <div id="ch-emp-rank"></div>
    </div>
    <div class="cbox">
      <div class="ctitle">🗺 Top จังหวัด</div>
      <div id="ch-prov" style="display:flex;flex-direction:column;gap:5px;padding-top:4px"></div>
