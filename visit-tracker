function addPhotos(files){
  const readers = files.map(f => new Promise(res => {
    const r = new FileReader();
    r.onload = ev => res({ dataUrl: ev.target.result, name: f.name, size: f.size, file: f });
    r.readAsDataURL(f);
  }));
  Promise.all(readers).then(results => {
    const isFirst = fPhotos.length === 0;
    fPhotos = [...fPhotos, ...results];
    renderPhotoGrid();
    if(isFirst && results.length > 0){
      readExif(results[0].file);  // อ่าน GPS + วันที่+เวลา จาก EXIF รูปแรก (ไม่ขอ browser GPS)
    }
  });
}

function readExif(file){
  const reader = new FileReader();
  reader.onload = function(e){
    try {
      const view = new DataView(e.target.result);
      const exif = parseExif(view);

      // วันที่+เวลาถ่ายจาก EXIF — บันทึกเสมอถ้ามี
      if(exif.date && exif.date.date){
        fPhotoDate = exif.date.date;
        fPhotoTime = exif.date.time || '';
      } else {
        // fallback: ใช้วันเวลาปัจจุบัน
        const now = new Date();
        fPhotoDate = now.toISOString().slice(0,10);
        fPhotoTime = now.toTimeString().slice(0,8);
      }

      // GPS จาก EXIF
      if(exif.gps && exif.gps.lat && !isNaN(exif.gps.lat)){
        fGPS = exif.gps;
        showGPSStatus('ok',
          '📍 GPS จาก EXIF: ' + fGPS.lat.toFixed(5) + ', ' + fGPS.lng.toFixed(5) +
          (fPhotoDate ? ' | 📅 ' + fPhotoDate + ' ' + fPhotoTime : ''));
      } else {
        // ไม่มี GPS แต่มีวันที่ — แสดงวันที่แทน
        const dateMsg = fPhotoDate ? ' | 📅 ถ่าย: ' + fPhotoDate + ' ' + fPhotoTime : '';
        showGPSStatus('warn', '⚠️ ไม่มี GPS ในรูป (เปิด Location ในกล้องก่อนถ่าย)' + dateMsg);
      }
    } catch(err){
      // EXIF อ่านไม่ได้ — fallback วันเวลาปัจจุบัน
      const now = new Date();
      fPhotoDate = now.toISOString().slice(0,10);
      fPhotoTime = now.toTimeString().slice(0,8);
      showGPSStatus('warn', '⚠️ อ่าน EXIF ไม่ได้ — ใช้วันเวลาปัจจุบันแทน');
    }
  };
  reader.readAsArrayBuffer(file);
}

function showGPSStatus(type, msg){
  const el = document.getElementById('gps-display');
  if(!el) return;
  el.style.display = 'block';
  el.className = 'gps-info ' + (type === 'ok' ? 'got' : 'err');
  el.textContent = msg;
}

function parseExif(view){
  const result = {};
  if(view.getUint16(0, false) !== 0xFFD8) return result; // not JPEG
  let offset = 2;
  while(offset < view.byteLength){
    if(view.getUint16(offset, false) === 0xFFE1){ // APP1
      if(view.getUint32(offset+4, false) === 0x45786966){ // "Exif"
        const little  = view.getUint16(offset+10, false) === 0x4949;
        const ifdOff  = view.getUint32(offset+14, little) + offset + 10;
        const entries = view.getUint16(ifdOff, little);
        for(let i = 0; i < entries; i++){
          const tag = view.getUint16(ifdOff + 2 + i*12, little);
          if(tag === 0x8769){ // ExifIFD
            const exifOff = view.getUint32(ifdOff + 2 + i*12 + 8, little) + offset + 10;
            result.date = readExifDate(view, exifOff, little, offset);
          }
          if(tag === 0x8825){ // GPSInfo
            const gpsOff = view.getUint32(ifdOff + 2 + i*12 + 8, little) + offset + 10;
            result.gps = readExifGPS(view, gpsOff, little, offset);
          }
        }
      }
      break;
    }
    offset += 2 + view.getUint16(offset+2, false);
  }
  return result;
}

function readExifDate(view, ifdOff, little, base){
  try {
    const entries = view.getUint16(ifdOff, little);
    for(let i = 0; i < entries; i++){
      const tag = view.getUint16(ifdOff + 2 + i*12, little);
      if(tag === 0x9003 || tag === 0x0132){ // DateTimeOriginal or DateTime
        const off = view.getUint32(ifdOff + 2 + i*12 + 8, little);
        let str = '';
        for(let j = 0; j < 19; j++){
          const ch = view.getUint8(base + 10 + off + j);
          if(ch === 0) break;
          str += String.fromCharCode(ch);
        }
        // Format: "2024:01:15 14:30:00" → {date:"2024-01-15", time:"14:30:00"}
        if(str.length >= 10){
          const parts = str.split(' ');
          return {
            date: parts[0].replace(/:/g, '-'),
            time: parts[1] || null
          };
        }
      }
    }
  } catch(e){}
  return null;
}

function readExifGPS(view, gpsOff, little, base){
  try {
    const entries = view.getUint16(gpsOff, little);
    let latRef='', lat=null, lngRef='', lng=null;
    for(let i = 0; i < entries; i++){
      const tag = view.getUint16(gpsOff + 2 + i*12, little);
      const cnt = view.getUint32(gpsOff + 2 + i*12 + 4, little);
      const valOff = view.getUint32(gpsOff + 2 + i*12 + 8, little);
      if(tag === 0x0001){ // LatRef N/S
        latRef = String.fromCharCode(view.getUint8(gpsOff + 2 + i*12 + 8));
      } else if(tag === 0x0003){ // LngRef E/W
        lngRef = String.fromCharCode(view.getUint8(gpsOff + 2 + i*12 + 8));
      } else if(tag === 0x0002 && cnt === 3){ // Lat
        lat = readRational3(view, base + 10 + valOff, little);
      } else if(tag === 0x0004 && cnt === 3){ // Lng
        lng = readRational3(view, base + 10 + valOff, little);
      }
    }
    if(lat !== null && lng !== null){
      const latDec = lat[0] + lat[1]/60 + lat[2]/3600;
      const lngDec = lng[0] + lng[1]/60 + lng[2]/3600;
      return {
        lat: latRef === 'S' ? -latDec : latDec,
        lng: lngRef === 'W' ? -lngDec : lngDec,
        acc: 0, src: 'exif'
      };
    }
  } catch(e){}
  return null;
}

function readRational3(view, off, little){
  const vals = [];
  for(let i = 0; i < 3; i++){
    const num = view.getUint32(off + i*8, little);
    const den = view.getUint32(off + i*8 + 4, little);
    vals.push(den ? num/den : 0);
  }
  return vals;
}

