async function pushToSheets(r){
  const url=DB.settings.gasUrl; if(!url) return {ok:false,err:'no url'};
  try{
    const photosToUpload = r.photos || [];

    // Step 1: บันทึกข้อมูลหลักใน Sheets
    const record={
      id:r.id, date:r.date, employee:r.employee,
      customer:r.customer, contact:r.contact,
      province:r.province, zone:r.zone,
      types:r.types||[], purposes:r.purposes||[], results:r.results||[],
      resultNote:r.resultNote||'', amount:r.amount||0,
      product:r.product||'', txn:r.txn||'', productNote:r.productNote||'',
      apptDate:r.apptDate||'', apptTime:r.apptTime||'', apptNote:r.apptNote||'',
      gps:r.gps||null, photoDate:r.photoDate||null, photoTime:r.photoTime||null,
      hasPhotos: photosToUpload.length,
      photos:[], sent:r.sent||false, createdAt:r.createdAt||new Date().toISOString()
    };

    const res1 = await gasPostWithRead(url, {action:'appendRecord', record});
    if(!res1.ok) return {ok:false, err:res1.err};
    const json1 = res1.data;
    if(!json1.success) return {ok:false, err:json1.error||'GAS error'};

    // Step 2: อัปโหลดรูป (ถ้ามี)
    let photoUrls = [];
    if(photosToUpload.length > 0){
      // ทำ Collage ใน browser ก่อน (แบบ v4) แล้วส่ง GAS รูปเดียว
      toast('📤 กำลังสร้าง Collage...','info');
      const compressed = await compressPhotos(photosToUpload);
      const collageB64 = await makeCollage(compressed);
      const collageKB  = collageB64 ? (collageB64.length/1024).toFixed(0) : 0;
      console.log(`Collage: ${collageKB}KB from ${compressed.length} photos`);
      toast(`📤 กำลังอัปโหลด Collage... [${collageKB}KB]`,'info');

      const res2 = await gasPostWithRead(url, {
        action:'uploadPhotos',
        recordId: String(r.id),
        customer: r.customer||'visit',
        photoDate: r.photoDate||null,
        photoTime: r.photoTime||null,
        photos: collageB64 ? [collageB64] : compressed    // ← ส่ง collage ใบเดียว
      }, 120000);

      if(res2.ok && res2.data){
        if(res2.data.photoUrls && res2.data.photoUrls.length > 0){
          photoUrls = res2.data.photoUrls;
          // Step 3: บันทึก link ลง Sheet
          await gasPostWithRead(url, {action:'updatePhotoUrls', id:String(r.id), photoUrls});
          toast('✅ อัปโหลดรูปสำเร็จ บันทึก link ลง Sheets แล้ว','ok');
          r.photoUrls = photoUrls;
          const idx = DB.records.findIndex(x=>x.id===r.id);
          if(idx>-1){ DB.records[idx].photoUrls = photoUrls; dbSave(); }
        } else if(res2.data.mode === 'no-cors'){
          // no-cors เกิดจากเปิดไฟล์แบบ file:// ต้อง deploy บน Netlify
          // GAS ได้รับและกำลังประมวลผลอยู่ รอ 30 วิแล้วตรวจ Sheet
          toast('⚠️ CORS: กรุณา deploy HTML บน Netlify (ไม่ใช่เปิดจากไฟล์ในเครื่อง)','err');
          console.warn('no-cors mode — deploy on HTTPS server to fix');
        } else {
          const errMsg = res2.data.error || JSON.stringify(res2.data).slice(0,100);
          toast('⚠️ อัปโหลดรูปไม่สำเร็จ: ' + errMsg,'err');
          console.error('uploadPhotos response:', res2.data);
        }
      } else {
        toast('⚠️ อัปโหลดรูปไม่สำเร็จ (ไม่ได้รับ response)','err');
      }
    }
    return {ok:true, data:{...json1, photoUrls}};
  }catch(e){
    console.error('pushToSheets:',e);
    return {ok:false, err:e.message};
  }
}


// GET request สำหรับ getRecords (ไม่มี CORS issue)
async function gasGetWithRead(url, timeoutMs){
  const controller = new AbortController();
  const tid = setTimeout(()=>controller.abort(), timeoutMs||30000);
  try{
    const res = await fetch(url, { method:'GET', redirect:'follow', signal: controller.signal });
    clearTimeout(tid);
    const text = await res.text();
    try{ return {ok:true, data:JSON.parse(text)}; }
    catch{ return {ok:false, err:'parse error: '+text.slice(0,100)}; }
  }catch(e){
    clearTimeout(tid);
    return {ok:false, err:e.message};
  }
}

// gasPost ที่อ่าน response ได้จริง (ไม่ fallback เป็น no-cors สำหรับกรณีที่ต้องการผล)
async function gasPostWithRead(url, payload, timeoutMs){
  const controller = new AbortController();
  const tid = setTimeout(()=>controller.abort(), timeoutMs||60000);
  try{
    const res = await fetch(url, {
      method:'POST',
      redirect:'follow',
      headers:{'Content-Type':'text/plain;charset=utf-8'},
      body: JSON.stringify(payload),
      signal: controller.signal
    });
    clearTimeout(tid);
    const text = await res.text();
    try{ return {ok:true, data:JSON.parse(text)}; }
    catch{ return {ok:true, data:{success:true, raw:text}}; }
  }catch(e){
    clearTimeout(tid);
    if(e.name==='AbortError'){
      return {ok:false, err:'timeout'};
    }
    // CORS error เกิดจากเปิดไฟล์แบบ file:// ในเครื่อง
    // ต้อง deploy บน server (Netlify) เพื่อให้ CORS ผ่าน
    // fallback no-cors — ส่งได้แต่อ่าน response ไม่ได้
    try{
      await fetch(url,{method:'POST',mode:'no-cors',
        headers:{'Content-Type':'text/plain;charset=utf-8'},
        body:JSON.stringify(payload)});
      return {ok:true, data:{success:true, mode:'no-cors'}};
    }catch(e2){ return {ok:false, err:e2.message}; }
  }
}

// Helper: POST to GAS with proper redirect handling
async function gasPost(url, payload){
  try{
    const res = await fetch(url, {
      method:'POST',
      redirect:'follow',
      headers:{'Content-Type':'text/plain;charset=utf-8'}, // GAS workaround
      body: JSON.stringify(payload)
    });
    const text = await res.text();
    try{ return {ok:true, data:JSON.parse(text)}; }
    catch{ return {ok:true, data:{success:true, raw:text}}; }
  }catch(e){
    // fallback: no-cors (ส่งได้แต่อ่าน response ไม่ได้)
    try{
      await fetch(url,{method:'POST',mode:'no-cors',
        headers:{'Content-Type':'text/plain;charset=utf-8'},
        body:JSON.stringify(payload)});
      return {ok:true, data:{success:true, mode:'no-cors'}};
    }catch(e2){ return {ok:false, err:e2.message}; }
  }
}

