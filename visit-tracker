const SAVE_STEPS = [
  { id:'s1', label:'บันทึกข้อมูลลง Sheets' },
  { id:'s2', label:'อัปโหลดรูปและสร้าง Collage' },
  { id:'s3', label:'บันทึกลิงก์รูปลง Sheets' },
  { id:'s4', label:'ส่งรายงานเข้า LINE' },
];

function progressShow(hasPhotos, mode){
  const box = document.getElementById('save-progress');
  const stepsEl = document.getElementById('prog-steps');
  box.style.display = 'block';
  // กำหนด step ที่จะแสดงตาม mode
  const steps = [SAVE_STEPS[0]];
  if(hasPhotos){ steps.push(SAVE_STEPS[1]); steps.push(SAVE_STEPS[2]); }
  if(mode==='now') steps.push(SAVE_STEPS[3]);
  stepsEl.innerHTML = steps.map(s=>
    `<div class="prog-step" id="${s.id}"><span class="prog-icon">⬜</span><span>${s.label}</span></div>`
  ).join('');
  progressSet(0, 'กำลังเริ่มต้น...');
}

function progressSet(pct, title){
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('prog-pct').textContent = pct + '%';
  document.getElementById('prog-title').textContent = title;
}

function progressStep(id, status, label){
  const el = document.getElementById(id); if(!el) return;
  el.className = 'prog-step ' + status;
  const icon = status==='done'?'✅' : status==='active'?'🔄' : status==='err'?'❌' : status==='skip'?'⏭':'⬜';
  el.querySelector('.prog-icon').textContent = icon;
  if(label) el.querySelector('span:last-child').textContent = label;
}

function progressDone(success){
  const pct = success ? 100 : document.getElementById('prog-fill').style.width.replace('%','');
  progressSet(success ? 100 : parseInt(pct), success ? '✅ เสร็จสมบูรณ์!' : '⚠️ เสร็จ (มีบางขั้นไม่สำเร็จ)');
  if(success){
    document.getElementById('prog-fill').style.background = 'var(--green)';
  }
  // ซ่อนหลัง 4 วิ
  setTimeout(()=>{
    const box = document.getElementById('save-progress');
    box.style.opacity='0';
    box.style.transition='opacity .5s';
    setTimeout(()=>{ box.style.display='none'; box.style.opacity='1'; }, 500);
  }, 4000);
}

