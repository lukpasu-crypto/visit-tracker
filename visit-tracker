function buildMsg(recs){
  const sep = '─'.repeat(30);
  const today = new Date().toLocaleDateString('th-TH',{year:'numeric',month:'long',day:'numeric'});
  const fmt   = DB.settings.msgFmt;

  // แยกตาม Sale เหมือน buildSaleReport ใน GAS
  const empMap = {};
  recs.forEach(r=>{
    const n = r.employee||'ไม่ระบุ';
    if(!empMap[n]) empMap[n]=[];
    empMap[n].push(r);
  });

  const parts = [];

  Object.keys(empMap).sort().forEach(name=>{
    const empRecs = empMap[name];
    const amt    = empRecs.reduce((s,r)=>s+(r.amount||0),0);
    const closed = empRecs.filter(r=>r.results&&r.results.some(x=>x==='closed')).length;

    // หัวรายงาน Sale
    let msg = `👤  รายงาน: ${name}\n`;
    msg += `📅  ${today}  |  เยี่ยม ${empRecs.length} ราย\n`;
    msg += sep + '\n';

    empRecs.forEach((r,i)=>{
      // 🕐 = เวลาที่บันทึกข้อมูล (createdAt)
      let recTime = '';
      if(r.createdAt){
        try{
          const dt = new Date(r.createdAt);
          recTime = dt.toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit',hour12:false});
        }catch(e){}
      }

      // Drive link: ใช้ /file/d/.../view เหมือนเดิม
      const driveUrl = r.photoUrls&&r.photoUrls.length>0 ? r.photoUrls[0] : '';
      // แปลง uc?export=view → /file/d/.../view ถ้าเป็นรูปแบบเก่า
      let collageUrl = driveUrl;
      if(driveUrl.includes('uc?export=view')){
        const m = driveUrl.match(/[?&]id=([^&]+)/);
        if(m) collageUrl = 'https://drive.google.com/file/d/'+m[1]+'/view';
      }
      const photoCount = r.hasPhotos||(r.photos&&r.photos.length)||0;

      msg += `\n${i+1}. ${r.customer}`;
      if(r.contact) msg += ` (${r.contact})`;
      msg += '\n';
      if(recTime) msg += `   🕐 ${recTime} น.\n`;
      msg += `   📍 ${r.province}${r.zone?' · '+r.zone:''}\n`;
      if(r.types&&r.types.length) msg += `   🏷 ${r.types.map(t=>TYPE_LABEL[t]||t).join(', ')}\n`;

      if(fmt==='full'){
        if(r.purposes&&r.purposes.length) msg += `   🎯 ${r.purposes.map(p=>PURPOSE_LABEL[p]||p).join(', ')}\n`;
        if(r.results&&r.results.length)   msg += `   📌 ${r.results.map(x=>RESULT_LABEL[x]||x).join(', ')}\n`;
        if(r.resultNote) msg += `   📝 ${r.resultNote.slice(0,80)}${r.resultNote.length>80?'...':''}\n`;
        if(r.amount>0)   msg += `   💰 ฿${r.amount.toLocaleString()}\n`;
        if(r.product)    msg += `   📦 ${r.product}${r.txn?' ('+r.txn+')':''}\n`;
        if(r.apptDate)   msg += `   📅 นัด: ${r.apptDate}${r.apptTime?' '+r.apptTime:''}${r.apptNote?' — '+r.apptNote:''}\n`;
        if(collageUrl){
          msg += `   📸 ภาพร้านค้า (${photoCount||1} รูป)\n`;
          msg += `   🔗 ${collageUrl}\n`;
          if(r.photoDate) msg += `   📅 ถ่ายเมื่อ: ${r.photoDate}${r.photoTime?' '+r.photoTime:''}\n`;
          // GPS จากรูป (EXIF) หรือ browser
          if(r.gps&&r.gps.lat&&r.gps.lng){
            msg += `   📍 GPS: https://maps.google.com/?q=${r.gps.lat},${r.gps.lng}\n`;
          }
        }
      } else {
        if(r.results&&r.results.length) msg += `   📌 ${r.results.map(x=>RESULT_LABEL[x]||x).join(', ')}\n`;
        if(r.amount>0) msg += `   💰 ฿${r.amount.toLocaleString()}\n`;
        if(collageUrl) msg += `   🔗 ${collageUrl}\n`;
      }
      msg += sep + '\n';
    });

    msg += `\n✅ รวม ${empRecs.length} ราย`;
    if(amt>0) msg += `  |  💰 ฿${amt.toLocaleString()}`;
    if(closed>0) msg += `  |  🎯 ปิด ${closed} ราย`;
    parts.push(msg);
  });

  return parts.join('\n\n');
}

async function sendLineNow(recs){
  const url = DB.settings.gasUrl;
  if(url){
    try{
      // แยกตาม Sale — ส่งทีละคนเหมือน dailySendReport ใน GAS
      const empMap = {};
      recs.forEach(r=>{
        const n = r.employee||'ไม่ระบุ';
        if(!empMap[n]) empMap[n]=[];
        empMap[n].push(r);
      });

      for(const name of Object.keys(empMap).sort()){
        const empRecs = empMap[name];
        // สร้าง text report (มีลิงก์ Drive อยู่แล้ว ไม่ต้องส่งรูปแยก)
        const msg = buildMsg(empRecs);
        // ส่งแค่ข้อความ — ลิงก์รูปอยู่ในข้อความแล้ว
        await gasPost(url,{
          action: 'sendLine',
          message: msg
        });
      }

      recs.forEach(r=>{r.sent=true;r.sentAt=new Date().toISOString();});
      dbSave();updatePendingBar();

      // อัปเดตสถานะ "ส่งแล้ว" ใน Google Sheet ด้วย
      try{
        const ids = recs.map(r=>String(r.id));
        await gasPost(url,{ action:'markSent', ids });
      }catch(e2){ console.warn('markSent error:',e2); }

      toast(`📲 ส่ง Line สำเร็จ ${recs.length} รายการ`,'ok');
      resetForm();return;
    }catch(e){ console.error('sendLineNow:',e); }
  }
  // fallback: ไม่มี GAS URL
  recs.forEach(r=>{r.sent=true;r.sentAt=new Date().toISOString();});
  dbSave();updatePendingBar();
  toast('📲 บันทึกแล้ว (ตั้ง GAS URL เพื่อส่ง Line จริง)','info');
  resetForm();
}

