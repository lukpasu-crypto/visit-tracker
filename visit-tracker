function toggleEditChip(el,t){
  const on=el.classList.contains('s-'+t);
  el.classList.toggle('s-'+t,!on);
}
function toggleEditPurpose(el){
  const on=el.classList.contains('s-purpose');
  el.classList.toggle('s-purpose',!on);
}
function setEditStar(n){document.querySelectorAll('#e-stars .star').forEach((s,i)=>s.classList.toggle('on',i<n));}

function saveEdit(){
  const idx=DB.records.findIndex(x=>x.id===editId); if(idx===-1)return;
  const types=[];
  document.querySelectorAll('#edit-body .chip').forEach(c=>{
    const t=c.dataset.type; if(c.classList.contains('s-'+t))types.push(t);
  });
  let stars=0;
  document.querySelectorAll('#e-stars .star').forEach((s,i)=>{if(s.classList.contains('on'))stars=i+1;});
  const ePurposes=[];
  document.querySelectorAll('#e-purpose-chips .chip').forEach(c=>{
    if(c.classList.contains('s-purpose'))ePurposes.push(c.dataset.purpose);
  });
  DB.records[idx]={...DB.records[idx],
    employee:document.getElementById('e-emp').value,
    date:document.getElementById('e-date').value,
    customer:document.getElementById('e-cust').value,
    contact:document.getElementById('e-contact').value,
    province:document.getElementById('e-prov').value,
    zone:document.getElementById('e-zone').value,
    types,stars,
    purposes:ePurposes,
    result:document.getElementById('e-result').value,
    resultNote:document.getElementById('e-rnote').value,
    amount:parseFloat(document.getElementById('e-amt').value)||0,
    product:document.getElementById('e-prod').value,
    apptDate:document.getElementById('e-adate').value,
    apptNote:document.getElementById('e-anote').value,
  };
  dbSave();closeModal('edit-modal');renderHistory();renderDashboard();toast('✅ แก้ไขสำเร็จ','ok');
}

function deleteRec(){
  if(!confirm('ลบรายการนี้?'))return;
  DB.records=DB.records.filter(x=>x.id!==editId);
  dbSave();closeModal('edit-modal');renderHistory();renderDashboard();updatePendingBar();toast('🗑 ลบแล้ว','info');
}

function closeModal(id){document.getElementById(id).classList.remove('open');editId=null;}


