function nav(el){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  const pg=el.dataset.page;
  document.getElementById('page-'+pg).classList.add('active');
  if(pg==='dashboard'){ renderDashboard(); autoSyncDashboard(); }
  if(pg==='history')renderHistory();
  if(pg==='master')renderMaster();
  if(pg==='settings')loadSettingsUI();
}

function mobNav(el){
  document.querySelectorAll('.mob-nav-item').forEach(n=>{
    n.classList.remove('active');
    const ind=n.querySelector('.mob-indicator');
    if(ind) ind.style.display='none';
  });
  el.classList.add('active');
  const ind=el.querySelector('.mob-indicator');
  if(ind) ind.style.display='';

  const pg=el.dataset.page;
  const pageEl=document.getElementById('page-'+pg);
  if(!pageEl) return;

  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  pageEl.classList.add('active');

  // sync desktop sidebar
  document.querySelectorAll('.nav-item').forEach(n=>{
    n.classList.toggle('active', n.dataset.page===pg);
  });

  if(pg==='dashboard'){ renderDashboard(); autoSyncDashboard(); }
  if(pg==='history')   renderHistory();
  if(pg==='settings')  loadSettingsUI();

  document.querySelector('.main').scrollTo(0,0);
}

