    if(pin === null) return;  // กด Cancel
    const storedPin = DB.settings.adminPin || "1234";  // default PIN = 1234
    if(pin === storedPin){
      _adminMode = true;
      applyAdminMode();
      toast('✅ เข้าสู่โหมด Admin','ok');
    } else {
      toast('❌ รหัสไม่ถูกต้อง','err');
    }
  }
}

function applyAdminMode(){
  const page = document.getElementById('page-settings');
  const bar  = document.getElementById('admin-bar');
  const barLabel = document.getElementById('admin-bar-label');
  const btn  = bar ? bar.querySelector('button') : null;

  if(_adminMode){
    page.classList.add('admin-mode');
    if(bar){ bar.classList.remove('locked'); bar.style.background='var(--accent)'; }
    if(barLabel) barLabel.textContent = '🔓 โหมด Admin — แก้ไขได้ทุกอย่าง';
    if(btn) btn.textContent = '🚪 ออก Admin';
  } else {
    page.classList.remove('admin-mode');
    if(bar){ bar.classList.add('locked'); bar.style.background=''; }
    if(barLabel) barLabel.textContent = '🔒 โหมดพนักงาน — แก้ได้เฉพาะชื่อของตัวเอง';
    if(btn) btn.textContent = '🔑 Admin';
  }
}

function saveMyName(){
  const name = document.getElementById('my-name').value.trim();
  if(!name){ toast('กรุณากรอกชื่อ','err'); return; }
  DB.settings.myName = name;
  dbSave();
  // ถ้าชื่อนี้ยังไม่อยู่ใน employees list ถามว่าจะเพิ่มไหม
  if(!DB.employees.includes(name)){
    if(confirm('เพิ่ม "' + name + '" เข้าในรายชื่อพนักงานด้วยไหม?')){
      DB.employees.push(name);
      dbSave(); populateAll(); renderMaster();
    }
  }
  // set เป็นค่า default ในฟอร์มบันทึก
  const empSel = document.getElementById('f-emp');
  if(empSel) empSel.value = name;
  toast('✅ บันทึกชื่อ "' + name + '" แล้ว','ok');
}

function loadMyName(){
  const name = DB.settings.myName || "";
  const el = document.getElementById('my-name');
  if(el) el.value = name;
  // set default ในฟอร์ม
  if(name){
    const empSel = document.getElementById('f-emp');
    if(empSel && empSel.value === "") empSel.value = name;
  }
}

// ══════════════════════════════════════════════
// MASTER
// ══════════════════════════════════════════════
function renderMaster(){
  // emp-list appears on both settings and master pages (settings only now)
  ['emp-list'].forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.innerHTML=DB.employees.map((e,i)=>`
      <div class="tag"><span>${e}</span><button class="tag-del" onclick="removeEmp(${i})">×</button></div>`).join('')||
      '<span style="font-size:12px;color:var(--text3)">ยังไม่มีพนักงาน</span>';
  });
}

function addEmp(){const n=document.getElementById('new-emp').value.trim();if(!n)return;if(DB.employees.includes(n)){toast('มีชื่อนี้แล้ว','err');return;}DB.employees.push(n);dbSave();populateAll();renderMaster();document.getElementById('new-emp').value='';toast(`✅ เพิ่ม ${n}`,'ok');}
function removeEmp(i){DB.employees.splice(i,1);dbSave();populateAll();renderMaster();}
function addZone(){const n=document.getElementById('new-zone').value.trim();if(!n)return;DB.zones.push(n);dbSave();populateAll();renderMaster();document.getElementById('new-zone').value='';toast(`✅ เพิ่มโซน ${n}`,'ok');}
function removeZone(i){DB.zones.splice(i,1);dbSave();populateAll();renderMaster();}
function addProv(){const n=document.getElementById('new-prov').value.trim();if(!n)return;DB.extraProvinces.push(n);dbSave();populateAll();renderMaster();document.getElementById('new-prov').value='';toast(`✅ เพิ่ม ${n}`,'ok');}
function removeProv(i){DB.extraProvinces.splice(i,1);dbSave();populateAll();renderMaster();}

// ══════════════════════════════════════════════
// SETTINGS
// ══════════════════════════════════════════════
function loadSettingsUI(){
  const s=DB.settings;
  document.getElementById('s-gas-url').value=s.gasUrl||'';
  document.getElementById('s-line-token').value=s.lineToken||'';
  document.getElementById('s-line-group').value=s.lineGroup||'';
  document.getElementById('s-line-user').value=s.lineUser||'';
  document.getElementById('s-auto').checked=s.autoSend;
  document.getElementById('s-fmt').value=s.msgFmt||'full';
  loadMyName();
  applyAdminMode();  // เริ่มต้นเสมอในโหมดล็อก
}
function saveSettings(){
  if(!_adminMode){ toast('❌ ต้องเข้าโหมด Admin ก่อน','err'); return; }
  DB.settings.gasUrl=document.getElementById('s-gas-url').value.trim();
  DB.settings.lineToken=document.getElementById('s-line-token').value.trim();
  DB.settings.lineGroup=document.getElementById('s-line-group').value.trim();
  DB.settings.lineUser=document.getElementById('s-line-user').value.trim();
  DB.settings.autoSend=document.getElementById('s-auto').checked;
  DB.settings.msgFmt=document.getElementById('s-fmt').value;
  dbSave();updateConn();toast('✅ บันทึกการตั้งค่าแล้ว','ok');
}

function setAdminPin(){
  if(!_adminMode){ toast('❌ ต้องเข้าโหมด Admin ก่อน','err'); return; }
  const newPin = prompt('ตั้ง PIN ใหม่ (ตัวเลข 4-8 หลัก):');
  if(!newPin || newPin.length < 4){ toast('PIN ต้องมีอย่างน้อย 4 ตัว','err'); return; }
  DB.settings.adminPin = newPin;
  dbSave();
  toast('✅ ตั้ง PIN ใหม่สำเร็จ','ok');
}

// ══════════════════════════════════════════════
// EXPORT / IMPORT
// ══════════════════════════════════════════════
function exportCSV(){
  const hdr='ID,วันที่,พนักงาน,ลูกค้า,ผู้ติดต่อ,จังหวัด,โซน,ประเภท,วัตถุประสงค์,ผลการเยี่ยม,รายละเอียดผล,ยอด,คะแนน,สินค้า,ธุรกรรม,วันนัดถัดไป,หมายเหตุนัด,GPS,รูปภาพ,Line,วันที่ส่ง';
  const rows=DB.records.map(r=>[
    r.id,r.date,r.employee,r.customer,r.contact||'',r.province,r.zone||'',
    r.types.map(t=>TYPE_LABEL[t]).join('+'),r.purpose,r.result,r.resultNote,
    r.amount,r.stars,r.product,r.txn||'',r.apptDate||'',r.apptNote||'',
    r.gps?`${r.gps.lat},${r.gps.lng}`:'',r.photos?r.photos.length:0,
    r.sent?'ส่งแล้ว':'รอส่ง',r.sentAt||''
  ].map(v=>`"${(v||'').toString().replace(/"/g,'""')}"`).join(','));
  dl('\uFEFF'+[hdr,...rows].join('\n'),`visit-${new Date().toISOString().slice(0,10)}.csv`,'text/csv;charset=utf-8');
}

function exportJSON(){
  const exp={...DB,photos_note:'Photos stored as base64 dataURL',exportedAt:new Date().toISOString()};
  dl(JSON.stringify(exp,null,2),`backup-${new Date().toISOString().slice(0,10)}.json`,'application/json');
}

function importJSON(e){
  const f=e.target.files[0]; if(!f)return;
  const rd=new FileReader();
  rd.onload=ev=>{
    try{
      const d=JSON.parse(ev.target.result);
      if(d.records)DB.records=d.records;
      if(d.employees)DB.employees=d.employees;
      if(d.zones)DB.zones=d.zones;
      if(d.extraProvinces)DB.extraProvinces=d.extraProvinces;
      if(d.settings)DB.settings={...DB.settings,...d.settings};
      dbSave();populateAll();renderHistory();renderDashboard();renderMaster();updateConn();updatePendingBar();
      toast(`✅ นำเข้า ${DB.records.length} รายการ`,'ok');
    }catch{toast('❌ ไฟล์ไม่ถูกต้อง','err');}
  };
  rd.readAsText(f);e.target.value='';
}

function clearAll(){
  if(!confirm('⚠️ ล้างข้อมูลทั้งหมด?'))return;
  DB.records=[];dbSave();renderHistory();renderDashboard();updatePendingBar();toast('🗑 ล้างข้อมูลแล้ว','info');
}

function clearLocalStorage(){
  if(!confirm('⚠️ ล้าง cache รูปภาพใน browser?\nข้อมูลและ Drive link ยังคงอยู่ใน Google Sheets'))return;
  // ล้าง photos base64 ทุก record แล้ว save ใหม่
  DB.records.forEach(r=>{ r.photos=[]; });
  try{
    localStorage.setItem('cvs3', JSON.stringify(DB));
    toast('✅ ล้าง cache รูปสำเร็จ — พื้นที่ว่างแล้ว','ok');
  } catch(e){
    localStorage.removeItem('cvs3');
    localStorage.setItem('cvs3', JSON.stringify(DB));
    toast('✅ ล้าง cache สำเร็จ','ok');
  }
}

function checkStorageUsage(){
  try{
    const used = new Blob([localStorage.getItem('cvs3')||'']).size;
    const usedKB = (used/1024).toFixed(1);
    const usedMB = (used/1024/1024).toFixed(2);
    toast('💾 ใช้พื้นที่: ' + usedKB + ' KB (' + usedMB + ' MB / ~5 MB)','info');
  } catch(e){ toast('ไม่สามารถตรวจสอบได้','err'); }
}

function dl(c,n,t='text/plain'){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([c],{type:t}));a.download=n;a.click();}

// ══════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════
function toast(msg,type='info'){
  const t=document.getElementById('toast');
  const el=document.createElement('div');
  el.className='ti '+(type==='ok'?'ok':type==='err'?'err':'info');
  el.textContent=msg; t.appendChild(el);
  setTimeout(()=>el.remove(),3500);
}

init();
</script>
