function validate(r){
  if(!r.employee) return 'กรุณาเลือกพนักงาน';
  if(!r.date)     return 'กรุณาเลือกวันที่';
  if(!r.customer) return 'กรุณากรอกชื่อลูกค้า';
  if(!r.province) return 'กรุณาเลือกจังหวัด';
  if(r.types.length===0) return 'กรุณาเลือกประเภทลูกค้า';
  if(r.purposes.length===0) return 'กรุณาเลือกวัตถุประสงค์';
  if(!r.resultNote) return 'กรุณากรอกผลการเยี่ยม';
  return null;
}

async function doSave(mode){
  const r=getFormData();
  const err=validate(r);
  if(err){toast(err,'err');return;}
  setLoading(true);

  const photosTemp = r.photos || [];
  progressShow(photosTemp.length > 0, mode);

  try{
    r.photos = [];
    r.hasPhotos = photosTemp.length;

    // ── ขั้น 1: บันทึกข้อมูลหลัก ──
    progressStep('s1','active');
    progressSet(10,'กำลังบันทึกข้อมูลลง Sheets...');
    DB.records.unshift(r);
    dbSave();
    updatePendingBar();

    const rWithPhotos = {...r, photos: photosTemp};
    const gasRes = await pushToSheets(rWithPhotos);

    if(!gasRes.ok){
      progressStep('s1','err','บันทึก Sheets ไม่สำเร็จ');
      progressSet(20,'⚠️ บันทึกแล้ว แต่ส่ง Sheets ไม่สำเร็จ');
      toast('⚠️ บันทึกในเครื่องแล้ว แต่ส่ง Sheets ไม่สำเร็จ','info');
    } else {
      progressStep('s1','done');
      progressSet(photosTemp.length > 0 ? 40 : 80,'บันทึกข้อมูลสำเร็จ');

      if(gasRes.data && gasRes.data.photoUrls && gasRes.data.photoUrls.length>0){
        r.photoUrls = gasRes.data.photoUrls;
        const idx=DB.records.findIndex(x=>x.id===r.id);
        if(idx>-1){ DB.records[idx].photoUrls=r.photoUrls; dbSave(); }
        progressStep('s2','done');
        progressStep('s3','done');
        progressSet(mode==='now' ? 80 : 100,'รูปอัปโหลดสำเร็จ');
      } else if(photosTemp.length > 0){
        progressStep('s2','err','อัปโหลดรูปไม่สำเร็จ');
        progressStep('s3','skip','ข้ามเพราะไม่มีลิงก์รูป');
      }
    }

    if(mode==='now'){
      progressStep('s4','active');
      progressSet(85,'กำลังส่ง LINE...');
      await sendLineNow([r]);
      progressStep('s4','done');
      progressSet(100,'ส่ง LINE สำเร็จ');
      progressDone(true);
    } else {
      toast('✅ บันทึกสำเร็จ — จะส่ง Line 19:00 น.','ok');
      progressDone(gasRes.ok);
      resetForm();
    }
  }catch(e){
    toast('❌ '+e.message,'err');
    progressSet(0,'❌ เกิดข้อผิดพลาด');
    progressDone(false);
  }
  finally{setLoading(false);}
}

function setLoading(on){
  ['btn-save','btn-send'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.disabled=on;
  });
}


