function populateAll(){
  const allP=[...PROVINCES,...DB.extraProvinces].sort((a,b)=>a.localeCompare(b,'th'));
  ['f-province','h-prov'].forEach(id=>{
    const el=document.getElementById(id); if(!el)return;
    const first=el.options[0].cloneNode(true);
    el.innerHTML=''; el.appendChild(first);
    allP.forEach(p=>{const o=document.createElement('option');o.value=p;o.text=p;el.appendChild(o);});
  });
  ['f-emp','h-emp'].forEach(id=>{
    const el=document.getElementById(id); if(!el)return;
    const first=el.options[0].cloneNode(true);
    el.innerHTML=''; el.appendChild(first);
    DB.employees.forEach(e=>{const o=document.createElement('option');o.value=e;o.text=e;el.appendChild(o);});
