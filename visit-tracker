    <div style="margin:12px 0">
      <div class="fg" style="margin-bottom:7px"><label>ประเภทลูกค้า</label></div>
      <div class="chips">
        ${['tech','retail','wholesale','proj','gov'].map(t=>`<div class="chip ${r.types.includes(t)?'s-'+t:''}" data-type="${t}" onclick="toggleEditChip(this,'${t}')">${TYPE_LABEL[t]}</div>`).join('')}
